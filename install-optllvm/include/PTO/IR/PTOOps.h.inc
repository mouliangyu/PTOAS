        }
        return std::nullopt;
      }
      return std::nullopt;
    };

    auto as = getAddressSpace(getTile().getType());
    if (!as)
      return ::mlir::pto::PIPE::PIPE_UNASSIGNED;
    if (*as == ::mlir::pto::AddressSpace::ACC)
      return ::mlir::pto::PIPE::PIPE_FIX;
    if (*as == ::mlir::pto::AddressSpace::VEC)
      return ::mlir::pto::PIPE::PIPE_MTE3;
    return ::mlir::pto::PIPE::PIPE_UNASSIGNED;
