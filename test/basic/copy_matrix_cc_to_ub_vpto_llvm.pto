// RUN: ptoas --pto-arch=a5 --pto-backend=vpto --vpto-march=dav-c310-cube --vpto-emit-hivm-llvm %s -o - | FileCheck %s

module attributes {pto.target_arch = "a5"} {
  func.func @copy_matrix_cc_to_ub_probe() attributes {pto.kernel_kind = #pto.kernel_kind<cube>} {
    %c0_i64 = arith.constant 0 : i64
    %c16_i64 = arith.constant 16 : i64
    %c68720525568_i64 = arith.constant 68720525568 : i64

    %src = pto.castptr %c0_i64 : i64 -> !pto.ptr<f32, acc>
    %dst = pto.castptr %c0_i64 : i64 -> !pto.ptr<f32, ub>
    pto.copy_matrix_cc_to_ub %src, %dst, %c68720525568_i64, %c16_i64
      : !pto.ptr<f32, acc>, !pto.ptr<f32, ub>, i64, i64
    return
  }
}

// CHECK: declare void @llvm.hivm.FIX.L0C.TO.UB.f32.EXT(ptr addrspace(6), ptr addrspace(5), i64, i64)
// CHECK: call void @llvm.hivm.FIX.L0C.TO.UB.f32.EXT(ptr addrspace(6) null, ptr addrspace(5) null, i64 68720525568, i64 16)
