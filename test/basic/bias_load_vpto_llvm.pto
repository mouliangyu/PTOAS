// RUN: ptoas --pto-arch=a5 --pto-backend=vpto --vpto-march=dav-c310-cube --vpto-emit-hivm-llvm %s -o - | FileCheck %s

module attributes {pto.target_arch = "a5"} {
  func.func @bias_load_f16_to_f32() attributes {pto.kernel_kind = #pto.kernel_kind<cube>} {
    %c0 = arith.constant 0 : i64
    %c2 = arith.constant 2 : i64
    %c4 = arith.constant 4 : i64
    %src = pto.castptr %c0 : i64 -> !pto.ptr<f16, mat>
    %dst = pto.castptr %c0 : i64 -> !pto.ptr<f32, bias>

    pto.bias_load %src, %dst, %c4 nburst(%c2, %c0, %c0)
      : !pto.ptr<f16, mat>, !pto.ptr<f32, bias>, i64, i64, i64, i64
    return
  }
}

// CHECK: call void @llvm.hivm.MOV.L1.TO.BT.f16
// CHECK-SAME: i64 262184
