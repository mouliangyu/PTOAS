// RUN: ptoas --pto-arch=a5 --pto-backend=vpto --vpto-march=dav-c310-cube --vpto-emit-hivm-llvm %s -o - | FileCheck %s

module attributes {pto.target_arch = "a5"} {
  func.func @load_cbuf_to_cb_2dv2_control() attributes {pto.kernel_kind = #pto.kernel_kind<cube>} {
    %c0 = arith.constant 0 : i64
    %c2 = arith.constant 2 : i64
    %c3 = arith.constant 3 : i64
    %c4 = arith.constant 4 : i64
    %c5 = arith.constant 5 : i64
    %c6 = arith.constant 6 : i64
    %src = pto.castptr %c0 : i64 -> !pto.ptr<f16, mat>
    %dst = pto.castptr %c0 : i64 -> !pto.ptr<f16, right>

    pto.load_cbuf_to_cb %src, %dst, %c0, %c2, %c3, %c4, %c5, %c6 {transpose = true}
      : !pto.ptr<f16, mat>, !pto.ptr<f16, right>, i64, i64, i64, i64, i64, i64
    return
  }
}

// CHECK: call void @llvm.hivm.LOAD.L1.TO.L0B.2Dv2.f16
// CHECK-SAME: i64 4410931544064
// CHECK-SAME: i64 393221
// CHECK-SAME: i64 1
