// Test that ExpandTileOp + InlineLibCall + FoldTileBufIntrinsics pipeline
// expands pto.tmrgsort via the TileLang Python DSL templates
// lib/TileOps/tmrgsort_template.py.
//
// Pipeline: MemrefToTileBuf -> ExpandTileOp -> InlineLibCall -> FoldTileBufIntrinsics
//
// RUN: ptoas --pto-arch=a5 --pto-backend=vpto --enable-tile-op-expand %s -o - 2>/dev/null | FileCheck %s

// After the full tile-op-expand path on the VPTO backend, the original
// pto.tmrgsort should be lowered to vector-style VPTO IR.

// Format1 test: single source with blockLen
// CHECK-LABEL: func.func @TMRGSORT_FORMAT1
// CHECK-NOT: pto.tmrgsort ins
// CHECK: pto.vmrgsort4

module {
  func.func @TMRGSORT_FORMAT1() {
    // Format1: single source merge
    // blockLen=64 means 32 values + 32 indices (for half type)
    %src = pto.alloc_tile
      : !pto.tile_buf<loc=vec, dtype=f16, rows=1, cols=256, v_row=1, v_col=256,
                      blayout=row_major, slayout=none_box, fractal=512, pad=0>
    %dst = pto.alloc_tile
      : !pto.tile_buf<loc=vec, dtype=f16, rows=1, cols=256, v_row=1, v_col=256,
                      blayout=row_major, slayout=none_box, fractal=512, pad=0>

    pto.tmrgsort ins(%src, %blockLen : !pto.tile_buf<loc=vec, dtype=f16, rows=1, cols=256, v_row=1, v_col=256,
                                blayout=row_major, slayout=none_box, fractal=512, pad=0>, i32)
               outs(%dst : !pto.tile_buf<loc=vec, dtype=f16, rows=1, cols=256, v_row=1, v_col=256,
                                     blayout=row_major, slayout=none_box, fractal=512, pad=0>)
    return
  }

  // Format2 test: 4 sources merge
  // CHECK-LABEL: func.func @TMRGSORT_FORMAT2
  // CHECK-NOT: pto.tmrgsort ins
  // CHECK: pto.vmrgsort4
  // CHECK: pto.copy_ubuf_to_ubuf

  func.func @TMRGSORT_FORMAT2() {
    // Format2: merge 4 pre-sorted lists
    %src0 = pto.alloc_tile
      : !pto.tile_buf<loc=vec, dtype=f16, rows=1, cols=128, v_row=1, v_col=128,
                      blayout=row_major, slayout=none_box, fractal=512, pad=0>
    %src1 = pto.alloc_tile
      : !pto.tile_buf<loc=vec, dtype=f16, rows=1, cols=128, v_row=1, v_col=128,
                      blayout=row_major, slayout=none_box, fractal=512, pad=0>
    %src2 = pto.alloc_tile
      : !pto.tile_buf<loc=vec, dtype=f16, rows=1, cols=128, v_row=1, v_col=128,
                      blayout=row_major, slayout=none_box, fractal=512, pad=0>
    %src3 = pto.alloc_tile
      : !pto.tile_buf<loc=vec, dtype=f16, rows=1, cols=128, v_row=1, v_col=128,
                      blayout=row_major, slayout=none_box, fractal=512, pad=0>
    %dst = pto.alloc_tile
      : !pto.tile_buf<loc=vec, dtype=f16, rows=1, cols=512, v_row=1, v_col=512,
                      blayout=row_major, slayout=none_box, fractal=512, pad=0>
    %tmp = pto.alloc_tile
      : !pto.tile_buf<loc=vec, dtype=f16, rows=1, cols=512, v_row=1, v_col=512,
                      blayout=row_major, slayout=none_box, fractal=512, pad=0>
    %executed = pto.alloc_tile
      : !pto.tile_buf<loc=vec, dtype=ui16, rows=1, cols=4, v_row=1, v_col=4,
                      blayout=row_major, slayout=none_box, fractal=512, pad=0>

    pto.tmrgsort ins(%src0, %src1, %src2, %src3 {exhausted = false} :
                  !pto.tile_buf<loc=vec, dtype=f16, rows=1, cols=128, v_row=1, v_col=128,
                      blayout=row_major, slayout=none_box, fractal=512, pad=0>,
                  !pto.tile_buf<loc=vec, dtype=f16, rows=1, cols=128, v_row=1, v_col=128,
                      blayout=row_major, slayout=none_box, fractal=512, pad=0>,
                  !pto.tile_buf<loc=vec, dtype=f16, rows=1, cols=128, v_row=1, v_col=128,
                      blayout=row_major, slayout=none_box, fractal=512, pad=0>,
                  !pto.tile_buf<loc=vec, dtype=f16, rows=1, cols=128, v_row=1, v_col=128,
                      blayout=row_major, slayout=none_box, fractal=512, pad=0>)
               outs(%dst, %tmp, %executed :
                  !pto.tile_buf<loc=vec, dtype=f16, rows=1, cols=512, v_row=1, v_col=512,
                      blayout=row_major, slayout=none_box, fractal=512, pad=0>,
                  !pto.tile_buf<loc=vec, dtype=f16, rows=1, cols=512, v_row=1, v_col=512,
                      blayout=row_major, slayout=none_box, fractal=512, pad=0>,
                  !pto.tile_buf<loc=vec, dtype=ui16, rows=1, cols=4, v_row=1, v_col=4,
                      blayout=row_major, slayout=none_box, fractal=512, pad=0>)
    return
  }
}