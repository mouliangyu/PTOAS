// Test that ExpandTileOp + InlineLibCall + FoldTileBufIntrinsics pipeline
// expands pto.tmrgsort format1 (single input list) via the TileLang Python DSL template
// lib/TileOps/tmrgsort_template.py.
//
// Pipeline: MemrefToTileBuf -> ExpandTileOp -> InlineLibCall -> FoldTileBufIntrinsics
//
// RUN: ptoas --pto-arch=a5 --pto-backend=vpto --enable-tile-op-expand %s -o - 2>/dev/null | FileCheck %s

// After the full tile-op-expand path on the VPTO backend, the original
// pto.tmrgsort (format1: single input list) should be lowered to vmrgsort4.

// CHECK-LABEL: func.func @TMRGSORT_1LIST_F32
// CHECK-NOT: pto.tmrgsort ins
// CHECK: pto.vmrgsort4

// CHECK-LABEL: func.func @TMRGSORT_1LIST_F16
// CHECK-NOT: pto.tmrgsort ins
// CHECK: pto.vmrgsort4

module {
  // Format 1: single input list (internal block sorting) with f32
  func.func @TMRGSORT_1LIST_F32() {
    %src = pto.alloc_tile
      : !pto.tile_buf<loc=vec, dtype=f32, rows=1, cols=256, v_row=1, v_col=256,
                      blayout=row_major, slayout=none_box, fractal=512, pad=0>
    %dst = pto.alloc_tile
      : !pto.tile_buf<loc=vec, dtype=f32, rows=1, cols=256, v_row=1, v_col=256,
                      blayout=row_major, slayout=none_box, fractal=512, pad=0>
    %blockLen = arith.constant 64 : i32

    pto.tmrgsort ins(%src, %blockLen : !pto.tile_buf<loc=vec, dtype=f32, rows=1, cols=256, v_row=1, v_col=256,
                                blayout=row_major, slayout=none_box, fractal=512, pad=0>, i32)
               outs(%dst : !pto.tile_buf<loc=vec, dtype=f32, rows=1, cols=256, v_row=1, v_col=256,
                                     blayout=row_major, slayout=none_box, fractal=512, pad=0>)
    return
  }

  // Format 1: single input list (internal block sorting) with f16
  func.func @TMRGSORT_1LIST_F16() {
    %src = pto.alloc_tile
      : !pto.tile_buf<loc=vec, dtype=f16, rows=1, cols=256, v_row=1, v_col=256,
                      blayout=row_major, slayout=none_box, fractal=512, pad=0>
    %dst = pto.alloc_tile
      : !pto.tile_buf<loc=vec, dtype=f16, rows=1, cols=256, v_row=1, v_col=256,
                      blayout=row_major, slayout=none_box, fractal=512, pad=0>
    %blockLen = arith.constant 64 : i32

    pto.tmrgsort ins(%src, %blockLen : !pto.tile_buf<loc=vec, dtype=f16, rows=1, cols=256, v_row=1, v_col=256,
                                blayout=row_major, slayout=none_box, fractal=512, pad=0>, i32)
               outs(%dst : !pto.tile_buf<loc=vec, dtype=f16, rows=1, cols=256, v_row=1, v_col=256,
                                     blayout=row_major, slayout=none_box, fractal=512, pad=0>)
    return
  }
}