// Test that pto.tcmps can be lowered to vector-style VPTO IR via TileLang template.
//
// RUN: ptoas --pto-arch=a5 --pto-backend=vpto --enable-tile-op-expand %s -o - 2>/dev/null | FileCheck %s

// After TileLang template expansion, pto.tcmps should use vcmps + pdintlv_b8 + psts.
// CHECK: func.func @TCMPS
// CHECK-NOT: pto.tcmps ins
// CHECK: pto.vecscope
// CHECK: pto.vlds
// CHECK: pto.vcmps
// CHECK: pto.pdintlv_b8
// CHECK: pto.psts

module {
  func.func @TCMPS() {
    %a = pto.alloc_tile
      : !pto.tile_buf<loc=vec, dtype=f32, rows=16, cols=64, v_row=16, v_col=64,
                      blayout=row_major, slayout=none_box, fractal=512, pad=0>
    %mask_buf = pto.alloc_tile
      : !pto.tile_buf<loc=vec, dtype=ui8, rows=16, cols=64, v_row=16, v_col=64,
                      blayout=row_major, slayout=none_box, fractal=512, pad=0>
    %scalar = arith.constant 0.0 : f32

    pto.tcmps ins(%a, %scalar {cmpMode = #pto<cmp lt>} : !pto.tile_buf<loc=vec, dtype=f32, rows=16, cols=64, v_row=16, v_col=64,
                              blayout=row_major, slayout=none_box, fractal=512, pad=0>,
                                f32)
              outs(%mask_buf : !pto.tile_buf<loc=vec, dtype=ui8, rows=16, cols=64, v_row=16, v_col=64,
                                    blayout=row_major, slayout=none_box, fractal=512, pad=0>)
    return
  }
}
