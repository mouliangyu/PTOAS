// RUN: not ptoas --pto-arch=a5 %s 2>&1 | FileCheck %s
// Test: TSTORE.VEC layout and alignment validation for A5

module {
  // Case 1: Valid ND layout with proper alignment
  func.func @tstore_nd_aligned_valid(%ptr: !pto.ptr<f32>) {
    %c0 = arith.constant 0 : index
    %c1 = arith.constant 1 : index
    %c8 = arith.constant 8 : index
    
    %src = pto.alloc_tile : !pto.tile_buf<loc=vec, dtype=f32, rows=1, cols=8, v_row=1, v_col=8, blayout=row_major, slayout=none_box, fractal=512, pad=0>
    %tv = pto.make_tensor_view %ptr, shape = [%c1, %c1, %c1, %c1, %c8], strides = [%c8, %c8, %c8, %c8, %c1] : !pto.tensor_view<1x1x1x1x8xf32>
    %pv = pto.partition_view %tv, offsets = [%c0, %c0, %c0, %c0, %c0], sizes = [%c1, %c1, %c1, %c1, %c8] : !pto.tensor_view<1x1x1x1x8xf32> -> !pto.partition_tensor_view<1x1x1x1x8xf32>
    
    pto.tstore ins(%src : !pto.tile_buf<loc=vec, dtype=f32, rows=1, cols=8, v_row=1, v_col=8, blayout=row_major, slayout=none_box, fractal=512, pad=0>)
               outs(%pv : !pto.partition_tensor_view<1x1x1x1x8xf32>)
    return
  }

  // Case 2: ND layout with bad alignment (cols=3, rows=2, 3*4=12 not divisible by 32) - should fail
  func.func @tstore_nd_bad_alignment(%ptr: !pto.ptr<f32>) {
    %c0 = arith.constant 0 : index
    %c1 = arith.constant 1 : index
    %c2 = arith.constant 2 : index
    %c3 = arith.constant 3 : index
    
    %src = pto.alloc_tile : !pto.tile_buf<loc=vec, dtype=f32, rows=2, cols=3, v_row=2, v_col=3, blayout=row_major, slayout=none_box, fractal=512, pad=0>
    %tv = pto.make_tensor_view %ptr, shape = [%c2, %c1, %c1, %c1, %c3], strides = [%c3, %c3, %c3, %c3, %c1] : !pto.tensor_view<2x1x1x1x3xf32>
    %pv = pto.partition_view %tv, offsets = [%c0, %c0, %c0, %c0, %c0], sizes = [%c2, %c1, %c1, %c1, %c3] : !pto.tensor_view<2x1x1x1x3xf32> -> !pto.partition_tensor_view<2x1x1x1x3xf32>
    
    pto.tstore ins(%src : !pto.tile_buf<loc=vec, dtype=f32, rows=2, cols=3, v_row=2, v_col=3, blayout=row_major, slayout=none_box, fractal=512, pad=0>)
               outs(%pv : !pto.partition_tensor_view<2x1x1x1x3xf32>)
    return
  }
  // CHECK: expects A5 vec tstore ND format Cols*sizeof(dtype) to be divisible by 32

  // Case 3: DN layout with bad alignment (rows=3, cols=2, 3*4=12 not divisible by 32) - should fail
  func.func @tstore_dn_bad_alignment(%ptr: !pto.ptr<f32>) {
    %c0 = arith.constant 0 : index
    %c1 = arith.constant 1 : index
    %c2 = arith.constant 2 : index
    %c3 = arith.constant 3 : index
    
    %src = pto.alloc_tile : !pto.tile_buf<loc=vec, dtype=f32, rows=3, cols=2, v_row=3, v_col=2, blayout=col_major, slayout=none_box, fractal=512, pad=0>
    %tv = pto.make_tensor_view %ptr, shape = [%c3, %c1, %c1, %c1, %c2], strides = [%c2, %c2, %c2, %c2, %c1] : !pto.tensor_view<3x1x1x1x2xf32>
    %pv = pto.partition_view %tv, offsets = [%c0, %c0, %c0, %c0, %c0], sizes = [%c3, %c1, %c1, %c1, %c2] : !pto.tensor_view<3x1x1x1x2xf32> -> !pto.partition_tensor_view<3x1x1x1x2xf32>
    
    pto.tstore ins(%src : !pto.tile_buf<loc=vec, dtype=f32, rows=3, cols=2, v_row=3, v_col=2, blayout=col_major, slayout=none_box, fractal=512, pad=0>)
               outs(%pv : !pto.partition_tensor_view<3x1x1x1x2xf32>)
    return
  }
  // CHECK: expects A5 vec tstore DN format Rows*sizeof(dtype) to be divisible by 32

  // Case 4: Invalid layout - should fail
  func.func @tstore_invalid_layout(%ptr: !pto.ptr<f32>) {
    %c0 = arith.constant 0 : index
    %c1 = arith.constant 1 : index
    %c8 = arith.constant 8 : index
    
    %src = pto.alloc_tile : !pto.tile_buf<loc=vec, dtype=f32, rows=1, cols=8, v_row=1, v_col=8, blayout=row_major, slayout=row_major, fractal=512, pad=0>
    %tv = pto.make_tensor_view %ptr, shape = [%c1, %c1, %c1, %c1, %c8], strides = [%c8, %c8, %c8, %c8, %c1] : !pto.tensor_view<1x1x1x1x8xf32>
    %pv = pto.partition_view %tv, offsets = [%c0, %c0, %c0, %c0, %c0], sizes = [%c1, %c1, %c1, %c1, %c8] : !pto.tensor_view<1x1x1x1x8xf32> -> !pto.partition_tensor_view<1x1x1x1x8xf32>
    
    pto.tstore ins(%src : !pto.tile_buf<loc=vec, dtype=f32, rows=1, cols=8, v_row=1, v_col=8, blayout=row_major, slayout=row_major, fractal=512, pad=0>)
               outs(%pv : !pto.partition_tensor_view<1x1x1x1x8xf32>)
    return
  }
  // CHECK: expects A5 vec tstore src layout to be ND, DN, or NZ

  // Case 5: i16 type with alignment (16*2=32, divisible by 32) - valid
  func.func @tstore_i16_aligned(%ptr: !pto.ptr<i16>) {
    %c0 = arith.constant 0 : index
    %c1 = arith.constant 1 : index
    %c16 = arith.constant 16 : index
    
    %src = pto.alloc_tile : !pto.tile_buf<loc=vec, dtype=i16, rows=1, cols=16, v_row=1, v_col=16, blayout=row_major, slayout=none_box, fractal=512, pad=0>
    %tv = pto.make_tensor_view %ptr, shape = [%c1, %c1, %c1, %c1, %c16], strides = [%c16, %c16, %c16, %c16, %c1] : !pto.tensor_view<1x1x1x1x16xi16>
    %pv = pto.partition_view %tv, offsets = [%c0, %c0, %c0, %c0, %c0], sizes = [%c1, %c1, %c1, %c1, %c16] : !pto.tensor_view<1x1x1x1x16xi16> -> !pto.partition_tensor_view<1x1x1x1x16xi16>
    
    pto.tstore ins(%src : !pto.tile_buf<loc=vec, dtype=i16, rows=1, cols=16, v_row=1, v_col=16, blayout=row_major, slayout=none_box, fractal=512, pad=0>)
               outs(%pv : !pto.partition_tensor_view<1x1x1x1x16xi16>)
    return
  }
}