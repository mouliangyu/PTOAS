// RUN: ptoas --pto-arch=a5 --pto-backend=vpto --emit-vpto %s -o - | FileCheck %s --check-prefix=IR
// RUN: ptoas --pto-arch=a5 --pto-backend=vpto --vpto-emit-hivm-llvm %s -o - | FileCheck %s --check-prefix=LLVM

module attributes {pto.target_arch = "a5"} {
  func.func @kernel(%gm_a: !pto.ptr<f16, gm>,
                    %gm_b: !pto.ptr<f16, gm>,
                    %gm_c: !pto.ptr<f32, gm>,
                    %l1_a: !pto.ptr<f16, ub>,
                    %l1_b: !pto.ptr<f16, ub>,
                    %l0a: !pto.ptr<f16, ub>,
                    %l0b: !pto.ptr<f16, ub>,
                    %l0c: !pto.ptr<f32, ub>) {
    %c1 = arith.constant 1 : i64
    %c16 = arith.constant 16 : i64
    %c0 = arith.constant 0 : i64

    pto.vecscope {
      pto.copy_gm_to_cbuf_align_v2 %gm_a, %l1_a, %c1, %c16, %c0, %c0 : !pto.ptr<f16, gm>, !pto.ptr<f16, ub>, i64, i64, i64, i64
      pto.copy_gm_to_cbuf_align_v2 %gm_b, %l1_b, %c1, %c16, %c0, %c0 : !pto.ptr<f16, gm>, !pto.ptr<f16, ub>, i64, i64, i64, i64
      pto.load_cbuf_to_ca %l1_a, %l0a, %c16, %c16 : !pto.ptr<f16, ub>, !pto.ptr<f16, ub>, i64, i64
      pto.load_cbuf_to_cb %l1_b, %l0b, %c16, %c16 : !pto.ptr<f16, ub>, !pto.ptr<f16, ub>, i64, i64
      pto.vmatmul %l0a, %l0b, %l0c, %c16, %c16, %c16 : !pto.ptr<f16, ub>, !pto.ptr<f16, ub>, !pto.ptr<f32, ub>, i64, i64, i64
      pto.copy_matrix_cc_to_gm %l0c, %gm_c, %c16, %c16 : !pto.ptr<f32, ub>, !pto.ptr<f32, gm>, i64, i64
    }
    return
  }
}

// IR: pto.copy_gm_to_cbuf_align_v2
// IR: pto.load_cbuf_to_ca
// IR: pto.load_cbuf_to_cb
// IR: pto.vmatmul
// IR: pto.copy_matrix_cc_to_gm

// LLVM: declare void @llvm.hivm.MOV.OUT.TO.L1.ALIGN.V2.f16.DV
// LLVM: declare void @llvm.hivm.LOAD.L1.TO.L0A.2Dv2.f16
// LLVM: declare void @llvm.hivm.LOAD.L1.TO.L0B.2Dv2.f16
// LLVM: declare void @llvm.hivm.MAD.f162f32.c310
// LLVM: declare void @llvm.hivm.FIX.L0C.TO.OUT.f32.EXT
// LLVM: call void @llvm.hivm.MOV.OUT.TO.L1.ALIGN.V2.f16.DV
// LLVM: call void @llvm.hivm.LOAD.L1.TO.L0A.2Dv2.f16
// LLVM: call void @llvm.hivm.LOAD.L1.TO.L0B.2Dv2.f16
// LLVM: call void @llvm.hivm.MAD.f162f32.c310
// LLVM: call void @llvm.hivm.FIX.L0C.TO.OUT.f32.EXT
// LLVM-NOT: pto.copy_gm_to_cbuf_align_v2
// LLVM-NOT: pto.load_cbuf_to_ca
// LLVM-NOT: pto.load_cbuf_to_cb
// LLVM-NOT: pto.copy_matrix_cc_to_gm
