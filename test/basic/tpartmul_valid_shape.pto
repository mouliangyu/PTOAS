// RUN: not ptoas --pto-arch=a5 %s 2>&1 | FileCheck %s
// Test: TPARTMUL valid_shape pattern - at least one src must match dst

module {
  // Case 1: Both src smaller than dst but none matches - should fail
  func.func @tpartmul_both_smaller_none_match_fail() {
    %src0 = pto.alloc_tile : !pto.tile_buf<loc=vec, dtype=f32, rows=4, cols=64, v_row=2, v_col=32, blayout=row_major, slayout=none_box, fractal=512, pad=0>
    %src1 = pto.alloc_tile : !pto.tile_buf<loc=vec, dtype=f32, rows=4, cols=64, v_row=1, v_col=16, blayout=row_major, slayout=none_box, fractal=512, pad=0>
    %dst = pto.alloc_tile : !pto.tile_buf<loc=vec, dtype=f32, rows=4, cols=64, v_row=4, v_col=64, blayout=row_major, slayout=none_box, fractal=512, pad=0>
    
    pto.tpartmul ins(%src0, %src1 : !pto.tile_buf<loc=vec, dtype=f32, rows=4, cols=64, v_row=2, v_col=32, blayout=row_major, slayout=none_box, fractal=512, pad=0>, !pto.tile_buf<loc=vec, dtype=f32, rows=4, cols=64, v_row=1, v_col=16, blayout=row_major, slayout=none_box, fractal=512, pad=0>)
             outs(%dst : !pto.tile_buf<loc=vec, dtype=f32, rows=4, cols=64, v_row=4, v_col=64, blayout=row_major, slayout=none_box, fractal=512, pad=0>)
    return
  }
  // CHECK: expects at least one of src0/src1 valid_shape to match dst valid_shape
}
