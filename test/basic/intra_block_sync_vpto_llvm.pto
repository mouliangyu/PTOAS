// RUN: ptoas --pto-arch=a5 --pto-backend=vpto --vpto-emit-hivm-llvm %s -o - | FileCheck %s

module attributes {pto.target_arch = "a5"} {
  func.func @intra_block_sync_static_dynamic(%event_id: index) attributes {pto.kernel_kind = #pto.kernel_kind<vector>} {
    pto.sync.set <PIPE_FIX>, 0
    pto.sync.wait <PIPE_MTE3>, 0
    pto.sync.set <PIPE_FIX>, %event_id
    pto.sync.wait <PIPE_MTE3>, %event_id
    return
  }
}

// CHECK-LABEL: define void @intra_block_sync_static_dynamic(
// CHECK: call void @llvm.hivm.SET.INTRA.BLOCK.mode(i64 10, i64 0)
// CHECK: call void @llvm.hivm.WAIT.INTRA.BLOCK.mode(i64 5, i64 0)
// CHECK: call void @llvm.hivm.SET.INTRA.BLOCK.mode(i64 10, i64 %0)
// CHECK: call void @llvm.hivm.WAIT.INTRA.BLOCK.mode(i64 5, i64 %0)
