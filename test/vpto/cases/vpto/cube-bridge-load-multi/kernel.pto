// -----------------------------------------------------------------------------
// case: vpto/cube-bridge-load-multi
// family: vpto
// target_ops: pto.cube_load, pto.cube_load_nd2nz, pto.cube_load_dn2nz
// scenarios: cube bridge load wrappers with dma-like nburst/loop syntax
// -----------------------------------------------------------------------------
module attributes {pto.target_arch = "a5"} {
  func.func @cube_bridge_load_multi_kernel(%a_gm: !pto.ptr<f16, gm>,
                                           %b_gm: !pto.ptr<f16, gm>,
                                           %c_gm: !pto.ptr<f32, gm>) {
    %c0_i64 = arith.constant 0 : i64
    %c1_i64 = arith.constant 1 : i64
    %c4_i64 = arith.constant 4 : i64
    %c8_i64 = arith.constant 8 : i64
    %c16_i64 = arith.constant 16 : i64
    %true = arith.constant true
    %false = arith.constant false

    %gm_a = pto.castptr %c0_i64 : i64 -> !pto.ptr<f16, gm>
    %gm_b = pto.castptr %c0_i64 : i64 -> !pto.ptr<f16, gm>
    %l1_a = pto.castptr %c0_i64 : i64 -> !pto.ptr<f16, mat>
    %l1_b = pto.castptr %c0_i64 : i64 -> !pto.ptr<f16, mat>
    %l1_c = pto.castptr %c0_i64 : i64 -> !pto.ptr<f16, mat>

    pto.cube_load %gm_a, %l1_a, %c16_i64
      nburst(%c1_i64, %c0_i64, %c0_i64)
      loop(%c1_i64, %c1_i64, %c1_i64)
      : !pto.ptr<f16, gm>, !pto.ptr<f16, mat>, i64, i64, i64, i64, loop i64, i64, i64

    pto.cube_load_nd2nz %gm_a, %l1_b,
      %c0_i64, %c1_i64, %c0_i64, %c8_i64, %c4_i64, %c1_i64,
      %false, %c0_i64, %c0_i64,
      nburst(%c1_i64, %c1_i64, %c1_i64)
      loop(%c1_i64, %c4_i64, %c4_i64)
      : !pto.ptr<f16, gm>, !pto.ptr<f16, mat>,
        i64, i64, i64, i64, i64, i64, i1, i64, i64,
        i64, i64, i64, loop i64, i64, i64

    pto.cube_load_dn2nz %gm_b, %l1_c,
      %c0_i64, %c1_i64, %c0_i64, %c8_i64, %c4_i64, %c1_i64,
      %false, %c0_i64, %c0_i64,
      nburst(%c1_i64, %c1_i64, %c1_i64)
      loop(%c1_i64, %c4_i64, %c4_i64)
      : !pto.ptr<f16, gm>, !pto.ptr<f16, mat>,
        i64, i64, i64, i64, i64, i64, i1, i64, i64,
        i64, i64, i64, loop i64, i64, i64

    pto.barrier #pto.pipe<PIPE_ALL>
    return
  }
}
