// -----------------------------------------------------------------------------
// case: micro-op/predicate-load-store/pstu
// family: predicate-load-store
// target_ops: pto.pstu
// scenarios: unaligned-packed-store, state-update, representative-logical-elements
// -----------------------------------------------------------------------------
module attributes {pto.target_arch = "a5"} {
  func.func @pstu_kernel_2d(%arg0: !pto.ptr<f32, gm>,
                            %arg1: !pto.ptr<f32, gm>,
                            %arg2: !pto.ptr<ui8, gm>) {
    %c0 = arith.constant 0 : index
    %c1 = arith.constant 1 : index
    %c8 = arith.constant 8 : index
    %c0_i64 = arith.constant 0 : i64
    %c1024_i64 = arith.constant 1024 : i64
    %c1_i64 = arith.constant 1 : i64
    %c8_i64 = arith.constant 8 : i64
    %c13 = arith.constant 13 : i32

    %ub_mask = pto.castptr %c0_i64 : i64 -> !pto.ptr<ui8, ub>
    %ub_out = pto.castptr %c1024_i64 : i64 -> !pto.ptr<ui8, ub>

    pto.vecscope {
      scf.for %iter = %c0 to %c1 step %c1 {
        %align = pto.vldas %ub_mask : !pto.ptr<ui8, ub> -> !pto.align
        %value, %next = pto.plt_b32 %c13 : i32 -> !pto.mask, i32
        %align_out, %base_out = pto.pstu %align, %value, %ub_mask : !pto.align, !pto.mask, !pto.ptr<ui8, ub> -> !pto.align, !pto.ptr<ui8, ub>
        %loaded = pto.pld %base_out[%c0], "NORM" : !pto.ptr<ui8, ub>, index -> !pto.mask
        pto.psts %loaded, %ub_out[%c0] : !pto.mask, !pto.ptr<ui8, ub>
        %discard = pto.pnot %loaded, %loaded : !pto.mask, !pto.mask -> !pto.mask
      }
    }

    pto.set_flag["PIPE_V", "PIPE_MTE3", "EVENT_ID0"]
    pto.wait_flag["PIPE_V", "PIPE_MTE3", "EVENT_ID0"]
    pto.set_loop_size_ubtoout %c1_i64, %c1_i64 : i64, i64
    pto.copy_ubuf_to_gm %ub_out, %arg2, %c0_i64, %c1_i64, %c8_i64, %c0_i64, %c8_i64, %c8_i64 : !pto.ptr<ui8, ub>, !pto.ptr<ui8, gm>, i64, i64, i64, i64, i64, i64
    pto.barrier #pto.pipe<PIPE_ALL>
    return
  }
}
