    %false = arith.constant false
    pto.set_loop_size_outtoub %c1_i64, %c1_i64 : i64, i64
    pto.copy_gm_to_ubuf %arg0, %ub_lhs, %c0_i64, %c32_i64, %c128_i64, %c0_i64, %c0_i64, %false, %c0_i64, %c128_i64, %c128_i64 : !pto.ptr<f32, gm>, !pto.ptr<f32, ub>, i64, i64, i64, i64, i64, i1, i64, i64, i64
    pto.set_loop_size_outtoub %c1_i64, %c1_i64 : i64, i64
    pto.copy_gm_to_ubuf %arg1, %ub_rhs, %c0_i64, %c32_i64, %c128_i64, %c0_i64, %c0_i64, %false, %c0_i64, %c128_i64, %c128_i64 : !pto.ptr<f32, gm>, !pto.ptr<f32, ub>, i64, i64, i64, i64, i64, i1, i64, i64, i64

    pto.set_flag["PIPE_MTE2", "PIPE_V", "EVENT_ID0"]
    pto.wait_flag["PIPE_MTE2", "PIPE_V", "EVENT_ID0"]

    pto.vecscope {
      %_:1 = scf.for %iter = %c0 to %c8 step %c1 iter_args(%remaining = %c1024_i32) -> (i32) {
        %lane0 = arith.muli %iter, %c128 : index
        %lane1 = arith.addi %lane0, %c64 : index
        %byte_index = arith.muli %iter, %c16 : index
        %byte_offset = arith.index_castui %byte_index : index to i32
        %mask0, %next_remaining0 = pto.plt_b32 %remaining : i32 -> !pto.mask, i32
        %mask1, %next_remaining1 = pto.plt_b32 %next_remaining0 : i32 -> !pto.mask, i32
        %lhs0 = pto.vlds %ub_lhs[%lane0] : !pto.ptr<f32, ub> -> !pto.vreg<64xf32>
        %rhs0 = pto.vlds %ub_rhs[%lane0] : !pto.ptr<f32, ub> -> !pto.vreg<64xf32>
        %cmp0 = pto.vcmp %lhs0, %rhs0, %mask0, "eq" : !pto.vreg<64xf32>, !pto.vreg<64xf32>, !pto.mask -> !pto.mask
        %lhs1 = pto.vlds %ub_lhs[%lane1] : !pto.ptr<f32, ub> -> !pto.vreg<64xf32>
