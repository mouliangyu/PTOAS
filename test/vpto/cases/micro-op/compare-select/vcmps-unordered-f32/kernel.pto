// -----------------------------------------------------------------------------
// case: micro-op/compare-select/vcmps-unordered-f32
// family: compare-select
// target_ops: pto.vcmps
// scenarios: core-f32, full-mask, scalar-operand, exceptional-values
// -----------------------------------------------------------------------------
module attributes {pto.target_arch = "a5"} {
  func.func @vcmps_unordered_kernel_2d(%arg0: !pto.ptr<f32, gm>,
                                       %arg1: !pto.ptr<f32, gm>,
                                       %arg2: !pto.ptr<ui8, gm>) {
    %c0 = arith.constant 0 : index
    %c1 = arith.constant 1 : index
    %c8 = arith.constant 8 : index
    %c64 = arith.constant 64 : index
    %c128 = arith.constant 128 : index
    %c0_i64 = arith.constant 0 : i64
    %c1_i64 = arith.constant 1 : i64
    %c8_i64 = arith.constant 8 : i64
    %c32_i64 = arith.constant 32 : i64
    %c128_i64 = arith.constant 128 : i64
    %c1024_i32 = arith.constant 1024 : i32
    %nan = arith.constant 0x7FC00000 : f32

    %ub_in = pto.castptr %c0_i64 : i64 -> !pto.ptr<f32, ub>
    %ub_out = pto.castptr %c0_i64 : i64 -> !pto.ptr<ui8, ub>

    %false = arith.constant false
    pto.set_loop_size_outtoub %c1_i64, %c1_i64 : i64, i64
    pto.copy_gm_to_ubuf %arg0, %ub_in, %c0_i64, %c32_i64, %c128_i64, %c0_i64, %c0_i64, %false, %c0_i64, %c128_i64, %c128_i64 : !pto.ptr<f32, gm>, !pto.ptr<f32, ub>, i64, i64, i64, i64, i64, i1, i64, i64, i64

    pto.set_flag["PIPE_MTE2", "PIPE_V", "EVENT_ID0"]
    pto.wait_flag["PIPE_MTE2", "PIPE_V", "EVENT_ID0"]

    pto.vecscope {
      %_:1 = scf.for %iter = %c0 to %c8 step %c1 iter_args(%remaining = %c1024_i32) -> (i32) {
        %lhs_offset = arith.muli %iter, %c128 : index
        %store_offset = arith.muli %iter, %c8 : index
        %mask, %next_remaining = pto.plt_b32 %remaining : i32 -> !pto.mask<b32>, i32
        %vec = pto.vlds %ub_in[%lhs_offset] : !pto.ptr<f32, ub> -> !pto.vreg<64xf32>
        %pred = pto.vcmps %vec, %nan, %mask, "eq" : !pto.vreg<64xf32>, f32, !pto.mask<b32> -> !pto.mask<b32>
        pto.psts %pred, %ub_out[%store_offset], "NORM" : !pto.mask<b32>, !pto.ptr<ui8, ub>, index
        scf.yield %next_remaining : i32
      }
    }

    pto.set_flag["PIPE_V", "PIPE_MTE3", "EVENT_ID0"]
    pto.wait_flag["PIPE_V", "PIPE_MTE3", "EVENT_ID0"]
    pto.set_loop_size_ubtoout %c1_i64, %c1_i64 : i64, i64
    pto.copy_ubuf_to_gm %ub_out, %arg2, %c0_i64, %c1_i64, %c32_i64, %c0_i64, %c32_i64, %c32_i64 : !pto.ptr<ui8, ub>, !pto.ptr<ui8, gm>, i64, i64, i64, i64, i64, i64
    pto.barrier #pto.pipe<PIPE_ALL>
    return
  }
}
