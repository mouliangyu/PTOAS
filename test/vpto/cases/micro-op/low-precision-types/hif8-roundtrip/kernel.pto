module attributes {pto.target_arch = "a5"} {
  func.func @low_precision_hif8_roundtrip(
      %src_gm: !pto.ptr<!pto.hif8, gm>,
      %dst_gm: !pto.ptr<!pto.hif8, gm>)
      attributes {pto.kernel_kind = #pto.kernel_kind<vector>} {
    %c0 = arith.constant 0 : index
    %c0_i64 = arith.constant 0 : i64
    %c1_i64 = arith.constant 1 : i64
    %c8_i64 = arith.constant 8 : i64
    %c32_i64 = arith.constant 32 : i64
    %c256_i64 = arith.constant 256 : i64
    %false = arith.constant false

    %ub_in = pto.castptr %c0_i64 : i64 -> !pto.ptr<!pto.hif8, ub>
    %ub_out = pto.castptr %c256_i64 : i64 -> !pto.ptr<!pto.hif8, ub>

    pto.set_loop_size_outtoub %c1_i64, %c1_i64 : i64, i64
    pto.copy_gm_to_ubuf %src_gm, %ub_in, %c0_i64, %c8_i64, %c32_i64,
                        %c0_i64, %c0_i64, %false, %c0_i64, %c32_i64, %c32_i64
      : !pto.ptr<!pto.hif8, gm>, !pto.ptr<!pto.hif8, ub>, i64, i64, i64, i64, i64, i1, i64, i64, i64

    pto.set_flag["PIPE_MTE2", "PIPE_V", "EVENT_ID0"]
    pto.wait_flag["PIPE_MTE2", "PIPE_V", "EVENT_ID0"]

    pto.vecscope {
      %mask = pto.pset_b8 "PAT_ALL" : !pto.mask<b8>
      %loaded = pto.vlds %ub_in[%c0] : !pto.ptr<!pto.hif8, ub> -> !pto.vreg<256x!pto.hif8>
      pto.vsts %loaded, %ub_out[%c0], %mask : !pto.vreg<256x!pto.hif8>, !pto.ptr<!pto.hif8, ub>, !pto.mask<b8>
    }

    pto.set_flag["PIPE_V", "PIPE_MTE3", "EVENT_ID0"]
    pto.wait_flag["PIPE_V", "PIPE_MTE3", "EVENT_ID0"]

    pto.set_loop_size_ubtoout %c1_i64, %c1_i64 : i64, i64
    pto.copy_ubuf_to_gm %ub_out, %dst_gm, %c0_i64, %c8_i64, %c32_i64,
                        %c0_i64, %c32_i64, %c32_i64
      : !pto.ptr<!pto.hif8, ub>, !pto.ptr<!pto.hif8, gm>, i64, i64, i64, i64, i64, i64
    pto.barrier #pto.pipe<PIPE_ALL>
    return
  }
}
