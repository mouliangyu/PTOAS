// -----------------------------------------------------------------------------
// case: micro-op/vector-load-store/cbuf-ubuf-roundtrip-mixed
// family: vector-load-store
// target_ops: pto.copy_gm_to_cbuf, pto.copy_cbuf_to_ubuf, pto.copy_ubuf_to_cbuf
// scenarios: split-compile, cube-producer, vec-consumer, intra-block-sync
// -----------------------------------------------------------------------------

module attributes {pto.target_arch = "a5"} {
  func.func @cbuf_ubuf_roundtrip_mixed_kernel_mix_aic(%src_gm: !pto.ptr<i16, gm>,
                                                   %dst_gm: !pto.ptr<i16, gm>)
      attributes {pto.kernel_kind = #pto.kernel_kind<cube>} {
    %c0_i64 = arith.constant 0 : i64
    %c1_i64 = arith.constant 1 : i64
    %c16_i64 = arith.constant 16 : i64
    %c512_i64 = arith.constant 512 : i64

    %l1_rt = pto.castptr %c512_i64 : i64 -> !pto.ptr<i16, mat>
    %ub1 = pto.castptr %c512_i64 : i64 -> !pto.ptr<i16, ub>

    // Follow the working PTO-ISA tmov_ub2l1 handoff:
    // vec produces L1, cube waits on MTE1 before reading cbuf.
    pto.sync.wait <PIPE_MTE1>, 0
    pto.sync.wait <PIPE_MTE1>, 16

    pto.copy_cbuf_to_ubuf %l1_rt, %ub1, %c0_i64, %c1_i64, %c16_i64, %c0_i64, %c0_i64
      : !pto.ptr<i16, mat>, !pto.ptr<i16, ub>, i64, i64, i64, i64, i64
    pto.copy_cbuf_to_ubuf %l1_rt, %ub1, %c1_i64, %c1_i64, %c16_i64, %c0_i64, %c0_i64
      : !pto.ptr<i16, mat>, !pto.ptr<i16, ub>, i64, i64, i64, i64, i64

    // cube produces UB, vec waits on MTE3 for the return handoff.
    pto.sync.set <PIPE_FIX>, 1
    pto.sync.set <PIPE_FIX>, 17
    return
  }
}
