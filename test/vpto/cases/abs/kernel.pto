// =============================================================================
// abs_kernel_2d: Element-wise absolute value on a 32x32 f32 tile
// =============================================================================
// This kernel computes abs(input) for a 32x32 float32 matrix (1024 elements).
//
// Memory Layout:
//   - Input:  arg0 -> GM (Global Memory)
//   - Output: arg1 -> GM (Global Memory)
//   - UB (Unified Buffer) at offset 0:    input tile  (4096 bytes = 32*32*4)
//   - UB at offset 4096:                  output tile (4096 bytes = 32*32*4)
//
// Pipeline:
//   1. DMA: GM -> UB (MTE2 pipe) - copy input tile to UB
//   2. Sync: wait for MTE2 -> V pipe handoff
//   3. Compute: vabs on 64-element vectors (V pipe) - 16 iterations for 1024 elements
//   4. Sync: wait for V -> MTE3 pipe handoff
//   5. DMA: UB -> GM (MTE3 pipe) - copy result tile back to GM
// =============================================================================

module attributes {pto.target_arch = "a5"} {
  func.func @abs_kernel_2d(%arg0: !pto.ptr<f32, gm>, %arg1: !pto.ptr<f32, gm>) {
    // =========================================================================
    // Constants
    // =========================================================================
    %c0 = arith.constant 0 : index
    %c1 = arith.constant 1 : index
    %c0_i64 = arith.constant 0 : i64
    %c1_i64 = arith.constant 1 : i64
    %c32 = arith.constant 32 : index               // Tile dimension
    %c32_i64 = arith.constant 32 : i64             // Tile dimension as i64
    %c64 = arith.constant 64 : index               // Vector width (64 f32 per SIMD op)
    %c128_i64 = arith.constant 128 : i64           // Row stride in bytes (32 * 4)
    %c4096_i64 = arith.constant 4096 : i64         // Tile size in bytes (1024 * 4)
    %c1024 = arith.constant 1024 : index           // Total elements (32 * 32)
    %c1024_i32 = arith.constant 1024 : i32         // For predicate loop counter

    // =========================================================================
    // UB buffer pointers (address space = ub)
    // =========================================================================
    %ub_in = pto.castptr %c0_i64 : i64 -> !pto.ptr<f32, ub>       // Input at offset 0
    %ub_out = pto.castptr %c4096_i64 : i64 -> !pto.ptr<f32, ub>   // Output at offset 4096

    // =========================================================================
    // Stage 1: DMA GM -> UB (MTE2 pipe)
    // Copy 32x32 f32 tile from Global Memory to Unified Buffer
    // =========================================================================
    // Configure DMA loop size (single tile: 1x1 loop, no stride needed)
    pto.set_loop_size_outtoub %c1_i64, %c1_i64 : i64, i64

    // DMA copy: GM[arg0] -> UB[0]
    // Args: src, dst, sid=0, n_burst=32, len_burst=128,
    //       left_pad=0, right_pad=0, data_select=false, l2_cache=0, gm_stride=128, ub_stride=128
    %false = arith.constant false
    pto.copy_gm_to_ubuf %arg0, %ub_in, %c0_i64, %c32_i64, %c128_i64, %c0_i64, %c0_i64, %false, %c0_i64, %c128_i64, %c128_i64 : !pto.ptr<f32, gm>, !pto.ptr<f32, ub>, i64, i64, i64, i64, i64, i1, i64, i64, i64

    // =========================================================================
    // Sync: MTE2 -> V pipe handoff (wait for DMA to complete before compute)
    // =========================================================================
    pto.set_flag["PIPE_MTE2", "PIPE_V", "EVENT_ID0"]
    pto.wait_flag["PIPE_MTE2", "PIPE_V", "EVENT_ID0"]

    // =========================================================================
    // Stage 2: Compute vabs (V pipe)
    // Process 1024 elements as flat 1D array, 64 elements per iteration (16 iterations)
    // Use no-post-update vlds/vsts while keeping predicate generation inside vector scope
    // =========================================================================
    scf.for %arg2 = %c0 to %c1 step %c1 {
      // Predicated vector loop with explicit offsets (no post-update)
      %_:1 = scf.for %arg3 = %c0 to %c1024 step %c64 iter_args(%remaining = %c1024_i32) -> (i32) {
        // Generate predicate mask: if remaining >= 64, full mask; else partial mask for tail
        %mask, %next_remaining = pto.plt_b32 %remaining : i32 -> !pto.mask, i32

        // Load 64 f32 elements from UB input at current offset
        %vec_in = pto.vlds %ub_in[%arg3] : !pto.ptr<f32, ub> -> !pto.vreg<64xf32>

        // Compute element-wise absolute value with predicate mask
        %vec_out = pto.vabs %vec_in, %mask : !pto.vreg<64xf32>, !pto.mask -> !pto.vreg<64xf32>

        // Store result to UB output at current offset
        pto.vsts %vec_out, %ub_out[%arg3], %mask : !pto.vreg<64xf32>, !pto.ptr<f32, ub>, !pto.mask

        scf.yield %next_remaining : i32
      }
    } {llvm.loop.aivector_scope}

    // =========================================================================
    // Sync: V -> MTE3 pipe handoff (wait for compute to complete before DMA out)
    // =========================================================================
    pto.set_flag["PIPE_V", "PIPE_MTE3", "EVENT_ID0"]
    pto.wait_flag["PIPE_V", "PIPE_MTE3", "EVENT_ID0"]

    // =========================================================================
    // Stage 3: DMA UB -> GM (MTE3 pipe)
    // Copy result tile from Unified Buffer back to Global Memory
    // =========================================================================
    // Configure DMA loop size (single tile: 1x1 loop, no stride needed)
    pto.set_loop_size_ubtoout %c1_i64, %c1_i64 : i64, i64

    // DMA copy: UB[4096] -> GM[arg1]
    pto.copy_ubuf_to_gm %ub_out, %arg1, %c0_i64, %c32_i64, %c128_i64, %c0_i64, %c128_i64, %c128_i64 : !pto.ptr<f32, ub>, !pto.ptr<f32, gm>, i64, i64, i64, i64, i64, i64

    // =========================================================================
    // Final barrier: ensure all pipes complete before kernel exit
    // =========================================================================
    pto.barrier #pto.pipe<PIPE_ALL>

    return
  }
}
