// RUN: ptoas --pto-arch=a5 %s -o %t.o
// RUN: strings %t.o | FileCheck %s --check-prefix=OBJ

module attributes {pto.target_arch = "a5"} {
  module attributes {pto.backend = "emitc"} {
    func.func private @helper()

    func.func @entry() attributes {pto.aicore} {
      func.call @helper() : () -> ()
      return
    }
  }

  module attributes {
    pto.backend = "emitc",
    pto.kernel_kind = #pto.kernel_kind<vector>
  } {
    func.func public @helper() attributes {pto.kernel_kind = #pto.kernel_kind<vector>} {
      return
    }
  }
}

// OBJ: helper.cube
// OBJ: helper.vector
// OBJ: entry_mix_aic
// OBJ: entry_mix_aiv
