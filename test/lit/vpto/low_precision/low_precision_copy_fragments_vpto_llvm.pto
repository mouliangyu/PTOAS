// Guards low-precision copy callee fragments in VPTO LLVM lowering.
// RUN: ptoas --pto-arch=a5 --pto-backend=vpto --vpto-march=dav-c310-cube --vpto-emit-hivm-llvm %s -o - | FileCheck %s

module attributes {pto.target_arch = "a5"} {
  func.func @low_precision_copy_fragments_vpto_llvm(
      %src_gm_hif8: !pto.ptr<!pto.hif8, gm>,
      %dst_ub_hif8: !pto.ptr<!pto.hif8, ub>,
      %src_gm_fp8: !pto.ptr<f8E4M3FN, gm>,
      %dst_mat_fp8: !pto.ptr<f8E4M3FN, mat>,
      %src_gm_fp4: !pto.ptr<!pto.f4E2M1x2, gm>,
      %dst_mat_fp4: !pto.ptr<!pto.f4E2M1x2, mat>)
      attributes {pto.kernel_kind = #pto.kernel_kind<cube>} {
    %c0 = arith.constant 0 : i64
    %c1 = arith.constant 1 : i64
    %c16 = arith.constant 16 : i64
    %false = arith.constant false

    pto.copy_gm_to_ubuf %src_gm_hif8, %dst_ub_hif8, %c0, %c1, %c16,
                        %c0, %c0, %false, %c0, %c0, %c0
      : !pto.ptr<!pto.hif8, gm>, !pto.ptr<!pto.hif8, ub>, i64, i64, i64, i64, i64, i1, i64, i64, i64
    pto.copy_gm_to_cbuf %src_gm_fp8, %dst_mat_fp8, %c1, %c16, %c0, %c0
      : !pto.ptr<f8E4M3FN, gm>, !pto.ptr<f8E4M3FN, mat>, i64, i64, i64, i64
    pto.copy_gm_to_cbuf_multi_nd2nz %src_gm_fp4, %dst_mat_fp4,
                        %c0, %c1, %c0, %c16, %c16, %c16, %false
      : !pto.ptr<!pto.f4E2M1x2, gm>, !pto.ptr<!pto.f4E2M1x2, mat>,
        i64, i64, i64, i64, i64, i64, i1
    return
  }
}

// CHECK-LABEL: define void @low_precision_copy_fragments_vpto_llvm(
// CHECK: call void @llvm.hivm.MOV.OUT.TO.UB.ALIGN.V2.hif8.DV(
// CHECK: call void @llvm.hivm.MOV.OUT.TO.L1.ALIGN.V2.e4m3.DV(
// CHECK: call void @llvm.hivm.MOV.OUT.TO.L1.MULTI.ND2NZ.U8.V310(
