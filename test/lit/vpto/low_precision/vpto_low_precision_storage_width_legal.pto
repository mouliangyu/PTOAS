// Guards legal 1-byte storage low-precision types across VPTO memory and vreg ops.
// RUN: ptoas --pto-arch=a5 --pto-backend=vpto %s -o - 2>&1 | FileCheck %s --check-prefix=VPTO
// RUN: ptoas --pto-arch=a5 --pto-backend=vpto --vpto-emit-hivm-llvm %s -o - | FileCheck %s --check-prefix=LLVM

module attributes {pto.target_arch = "a5"} {
  func.func @vpto_low_precision_storage_width_legal(
      %src_gm_hif8: !pto.ptr<!pto.hif8, gm>,
      %dst_ub_hif8: !pto.ptr<!pto.hif8, ub>,
      %src_ub_hif8: !pto.ptr<!pto.hif8, ub>,
      %dst_gm_hif8: !pto.ptr<!pto.hif8, gm>,
      %lane_bits: !pto.vreg<256xi8>)
      attributes {pto.kernel_kind = #pto.kernel_kind<vector>} {
    %c0 = arith.constant 0 : index
    %c0_i64 = arith.constant 0 : i64
    %c1_i64 = arith.constant 1 : i64
    %c32_i64 = arith.constant 32 : i64
    %false = arith.constant false

    pto.copy_gm_to_ubuf %src_gm_hif8, %dst_ub_hif8, %c0_i64, %c1_i64, %c32_i64,
                        %c0_i64, %c0_i64, %false, %c0_i64, %c0_i64, %c0_i64
      : !pto.ptr<!pto.hif8, gm>, !pto.ptr<!pto.hif8, ub>, i64, i64, i64, i64, i64, i1, i64, i64, i64
    pto.copy_ubuf_to_gm %src_ub_hif8, %dst_gm_hif8, %c0_i64, %c1_i64, %c32_i64,
                        %c0_i64, %c0_i64, %c0_i64
      : !pto.ptr<!pto.hif8, ub>, !pto.ptr<!pto.hif8, gm>, i64, i64, i64, i64, i64, i64

    pto.vecscope {
      %mask = pto.pset_b8 "PAT_ALL" : !pto.mask<b8>
      %loaded = pto.vlds %src_ub_hif8[%c0] : !pto.ptr<!pto.hif8, ub> -> !pto.vreg<256x!pto.hif8>
      %cast = pto.vbitcast %loaded : !pto.vreg<256x!pto.hif8> -> !pto.vreg<256xui8>
      %sel = pto.vselr %loaded, %lane_bits : !pto.vreg<256x!pto.hif8>, !pto.vreg<256xi8> -> !pto.vreg<256x!pto.hif8>
      pto.vsts %sel, %dst_ub_hif8[%c0], %mask : !pto.vreg<256x!pto.hif8>, !pto.ptr<!pto.hif8, ub>, !pto.mask<b8>
    }
    return
  }
}

// VPTO-LABEL: func.func @vpto_low_precision_storage_width_legal(
// VPTO-SAME: !pto.ptr<!pto.hif8, gm>
// VPTO-SAME: !pto.ptr<!pto.hif8, ub>
// VPTO: pto.copy_gm_to_ubuf
// VPTO: pto.copy_ubuf_to_gm
// VPTO: %{{.*}} = pto.vlds %{{.*}}[%{{.*}}] : !pto.ptr<!pto.hif8, ub> -> !pto.vreg<256x!pto.hif8>
// VPTO: %{{.*}} = pto.vselr %{{.*}}, %{{.*}} : !pto.vreg<256x!pto.hif8>, !pto.vreg<256xi8> -> !pto.vreg<256x!pto.hif8>
// VPTO: pto.vsts %{{.*}}, %{{.*}}[%{{.*}}], %{{.*}} : !pto.vreg<256x!pto.hif8>, !pto.ptr<!pto.hif8, ub>, !pto.mask<b8>

// LLVM: declare void @llvm.hivm.MOV.OUT.TO.UB.ALIGN.V2.hif8.DV
// LLVM: declare <256 x i8> @llvm.hivm.vldsx1.v256hif8(ptr addrspace(6), i32, i32, i32)
// LLVM: declare <256 x i8> @llvm.hivm.vselr.v256hif8(<256 x i8>, <256 x i8>)
// LLVM: declare void @llvm.hivm.vstsx1.v256hif8(<256 x i8>, ptr addrspace(6), i32, i32, i32, <256 x i1>)
// LLVM-LABEL: define void @vpto_low_precision_storage_width_legal(
// LLVM: call void @llvm.hivm.MOV.OUT.TO.UB.ALIGN.V2.hif8.DV
// LLVM: call <256 x i8> @llvm.hivm.vldsx1.v256hif8(ptr addrspace(6)
// LLVM: call <256 x i8> @llvm.hivm.vselr.v256hif8(<256 x i8>
// LLVM: call void @llvm.hivm.vstsx1.v256hif8(<256 x i8>
