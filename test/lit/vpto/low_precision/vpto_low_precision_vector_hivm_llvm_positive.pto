// Guards Hivm LLVM vector lowering for supported low-precision element types.
// RUN: ptoas --pto-arch=a5 --pto-backend=vpto --vpto-emit-hivm-llvm %s -o - | FileCheck %s

module attributes {pto.target_arch = "a5"} {
  func.func @probe_fp8_llvm(
      %src_ub_fp8: !pto.ptr<f8E5M2, ub>,
      %dst_ub_fp8: !pto.ptr<f8E5M2, ub>,
      %lane_bits: !pto.vreg<256xi8>)
      attributes {pto.kernel_kind = #pto.kernel_kind<vector>} {
    %c0 = arith.constant 0 : index
    pto.vecscope {
      %mask = pto.pset_b8 "PAT_ALL" : !pto.mask<b8>
      %loaded = pto.vlds %src_ub_fp8[%c0] : !pto.ptr<f8E5M2, ub> -> !pto.vreg<256xf8E5M2>
      %sel = pto.vselr %loaded, %lane_bits : !pto.vreg<256xf8E5M2>, !pto.vreg<256xi8> -> !pto.vreg<256xf8E5M2>
      pto.vsts %sel, %dst_ub_fp8[%c0], %mask : !pto.vreg<256xf8E5M2>, !pto.ptr<f8E5M2, ub>, !pto.mask<b8>
    }
    return
  }

  func.func @probe_fp4_llvm(
      %src_ub_fp4: !pto.ptr<!pto.f4E2M1x2, ub>,
      %dst_ub_fp4: !pto.ptr<!pto.f4E2M1x2, ub>,
      %lane_bits: !pto.vreg<256xi8>)
      attributes {pto.kernel_kind = #pto.kernel_kind<vector>} {
    %c0 = arith.constant 0 : index
    pto.vecscope {
      %mask = pto.pset_b8 "PAT_ALL" : !pto.mask<b8>
      %loaded = pto.vlds %src_ub_fp4[%c0] : !pto.ptr<!pto.f4E2M1x2, ub> -> !pto.vreg<256x!pto.f4E2M1x2>
      %sel = pto.vselr %loaded, %lane_bits : !pto.vreg<256x!pto.f4E2M1x2>, !pto.vreg<256xi8> -> !pto.vreg<256x!pto.f4E2M1x2>
      pto.vsts %sel, %dst_ub_fp4[%c0], %mask : !pto.vreg<256x!pto.f4E2M1x2>, !pto.ptr<!pto.f4E2M1x2, ub>, !pto.mask<b8>
    }
    return
  }
}

// CHECK: declare <256 x i8> @llvm.hivm.vldsx1.v256e5m2(ptr addrspace(6), i32, i32, i32)
// CHECK: declare <256 x i8> @llvm.hivm.vselr.v256e5m2(<256 x i8>, <256 x i8>)
// CHECK: declare void @llvm.hivm.vstsx1.v256e5m2(<256 x i8>, ptr addrspace(6), i32, i32, i32, <256 x i1>)
// CHECK-NOT: @llvm.hivm.vldsx1.v256i8(
// CHECK-NOT: @llvm.hivm.vselr.v256i8(
// CHECK-NOT: @llvm.hivm.vstsx1.v256i8(

// CHECK: declare <256 x i8> @llvm.hivm.vldsx1.v256e2m1x2(ptr addrspace(6), i32, i32, i32)
// CHECK: declare <256 x i8> @llvm.hivm.vselr.v256e2m1x2(<256 x i8>, <256 x i8>)
// CHECK: declare void @llvm.hivm.vstsx1.v256e2m1x2(<256 x i8>, ptr addrspace(6), i32, i32, i32, <256 x i1>)
// CHECK-NOT: @llvm.hivm.vldsx1.v256ui8(
// CHECK-NOT: @llvm.hivm.vselr.v256ui8(
// CHECK-NOT: @llvm.hivm.vstsx1.v256ui8(

// CHECK-LABEL: define void @probe_fp8_llvm(
// CHECK: call <256 x i8> @llvm.hivm.vldsx1.v256e5m2(ptr addrspace(6) %0, i32 0, i32 0, i32 0)
// CHECK: call <256 x i8> @llvm.hivm.vselr.v256e5m2(<256 x i8> %{{.*}}, <256 x i8> %2)
// CHECK: call void @llvm.hivm.vstsx1.v256e5m2(<256 x i8> %{{.*}}, ptr addrspace(6) %1, i32 0, i32 0, i32 0, <256 x i1> %{{.*}})

// CHECK-LABEL: define void @probe_fp4_llvm(
// CHECK: call <256 x i8> @llvm.hivm.vldsx1.v256e2m1x2(ptr addrspace(6) %0, i32 0, i32 0, i32 0)
// CHECK: call <256 x i8> @llvm.hivm.vselr.v256e2m1x2(<256 x i8> %{{.*}}, <256 x i8> %2)
// CHECK: call void @llvm.hivm.vstsx1.v256e2m1x2(<256 x i8> %{{.*}}, ptr addrspace(6) %1, i32 0, i32 0, i32 0, <256 x i1> %{{.*}})
