// Guards rejection of unsupported low-precision scalar operands.
// RUN: not ptoas --pto-arch=a5 --pto-backend=vpto %s -o - 2>&1 | FileCheck %s

// CHECK: error: 'pto.vcmps' op scalar low-precision element type '!pto.hif8' is not supported by pto.vcmps yet
// CHECK-NOT: llvm.hivm.
// CHECK-NOT: v256i8
// CHECK-NOT: v256ui8

module attributes {pto.target_arch = "a5"} {
  func.func @reject_low_precision_vcmps_scalar(
      %src: !pto.vreg<128xf16>,
      %scalar: !pto.hif8,
      %mask: !pto.mask<b16>)
      attributes {pto.kernel_kind = #pto.kernel_kind<vector>} {
    pto.vecscope {
      %0 = pto.vcmps %src, %scalar, %mask, "eq" : !pto.vreg<128xf16>, !pto.hif8, !pto.mask<b16> -> !pto.mask<b16>
    }
    return
  }
}
