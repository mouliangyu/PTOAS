// Guards Hivm LLVM addptr lowering for low-precision GM and UB pointers.
// RUN: ptoas --pto-arch=a5 --pto-backend=vpto --vpto-emit-hivm-llvm %s -o - | FileCheck %s

module attributes {pto.target_arch = "a5"} {
  func.func @probe_fp8_addptr_llvm(
      %src_gm_fp8: !pto.ptr<f8E5M2, gm>,
      %dst_gm_fp8: !pto.ptr<f8E5M2, gm>)
      attributes {pto.kernel_kind = #pto.kernel_kind<vector>} {
    %c0 = arith.constant 0 : index
    %c0_i64 = arith.constant 0 : i64
    %c16_i64 = arith.constant 16 : i64
    %c64_i64 = arith.constant 64 : i64
    %false = arith.constant false

    %ub = pto.castptr %c0_i64 : i64 -> !pto.ptr<f8E5M2, ub>
    %src = pto.addptr %src_gm_fp8, %c0 : !pto.ptr<f8E5M2, gm> -> !pto.ptr<f8E5M2, gm>
    %dst_ub = pto.addptr %ub, %c0 : !pto.ptr<f8E5M2, ub> -> !pto.ptr<f8E5M2, ub>
    pto.copy_gm_to_ubuf %src, %dst_ub, %c0_i64, %c16_i64, %c64_i64, %c0_i64, %c0_i64, %false, %c0_i64, %c64_i64, %c64_i64
      : !pto.ptr<f8E5M2, gm>, !pto.ptr<f8E5M2, ub>, i64, i64, i64, i64, i64, i1, i64, i64, i64
    %dst = pto.addptr %dst_gm_fp8, %c0 : !pto.ptr<f8E5M2, gm> -> !pto.ptr<f8E5M2, gm>
    pto.copy_ubuf_to_gm %dst_ub, %dst, %c0_i64, %c16_i64, %c64_i64, %c0_i64, %c64_i64, %c64_i64
      : !pto.ptr<f8E5M2, ub>, !pto.ptr<f8E5M2, gm>, i64, i64, i64, i64, i64, i64
    return
  }

  func.func @probe_fp4_addptr_llvm(
      %src_gm_fp4: !pto.ptr<!pto.f4E2M1x2, gm>,
      %dst_gm_fp4: !pto.ptr<!pto.f4E2M1x2, gm>)
      attributes {pto.kernel_kind = #pto.kernel_kind<vector>} {
    %c0 = arith.constant 0 : index
    %c0_i64 = arith.constant 0 : i64
    %c16_i64 = arith.constant 16 : i64
    %c64_i64 = arith.constant 64 : i64
    %false = arith.constant false

    %ub = pto.castptr %c0_i64 : i64 -> !pto.ptr<!pto.f4E2M1x2, ub>
    %src = pto.addptr %src_gm_fp4, %c0 : !pto.ptr<!pto.f4E2M1x2, gm> -> !pto.ptr<!pto.f4E2M1x2, gm>
    %dst_ub = pto.addptr %ub, %c0 : !pto.ptr<!pto.f4E2M1x2, ub> -> !pto.ptr<!pto.f4E2M1x2, ub>
    pto.copy_gm_to_ubuf %src, %dst_ub, %c0_i64, %c16_i64, %c64_i64, %c0_i64, %c0_i64, %false, %c0_i64, %c64_i64, %c64_i64
      : !pto.ptr<!pto.f4E2M1x2, gm>, !pto.ptr<!pto.f4E2M1x2, ub>, i64, i64, i64, i64, i64, i1, i64, i64, i64
    %dst = pto.addptr %dst_gm_fp4, %c0 : !pto.ptr<!pto.f4E2M1x2, gm> -> !pto.ptr<!pto.f4E2M1x2, gm>
    pto.copy_ubuf_to_gm %dst_ub, %dst, %c0_i64, %c16_i64, %c64_i64, %c0_i64, %c64_i64, %c64_i64
      : !pto.ptr<!pto.f4E2M1x2, ub>, !pto.ptr<!pto.f4E2M1x2, gm>, i64, i64, i64, i64, i64, i64
    return
  }
}

// CHECK-DAG: declare void @llvm.hivm.MOV.OUT.TO.UB.ALIGN.V2.e5m2.DV
// CHECK-DAG: declare void @llvm.hivm.MOV.OUT.TO.UB.ALIGN.V2.e2m1x2.DV
// CHECK-DAG: declare void @llvm.hivm.MOV.UB.TO.OUT.ALIGN.V2.DV
// CHECK-LABEL: define void @probe_fp8_addptr_llvm(
// CHECK: getelementptr i8, ptr addrspace(1) %0, i64 0
// CHECK: call void @llvm.hivm.MOV.OUT.TO.UB.ALIGN.V2.e5m2.DV(ptr addrspace(6) null, ptr addrspace(1) %{{[0-9]+}},
// CHECK: getelementptr i8, ptr addrspace(1) %1, i64 0
// CHECK: call void @llvm.hivm.MOV.UB.TO.OUT.ALIGN.V2.DV

// CHECK-LABEL: define void @probe_fp4_addptr_llvm(
// CHECK: getelementptr i8, ptr addrspace(1) %0, i64 0
// CHECK: call void @llvm.hivm.MOV.OUT.TO.UB.ALIGN.V2.e2m1x2.DV(ptr addrspace(6) null, ptr addrspace(1) %{{[0-9]+}},
// CHECK: getelementptr i8, ptr addrspace(1) %1, i64 0
// CHECK: call void @llvm.hivm.MOV.UB.TO.OUT.ALIGN.V2.DV
// CHECK-NOT: !pto.f4E2M1x2
