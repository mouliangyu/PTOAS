// Guards A5 target-feature selection for low-precision VPTO LLVM emission.
// RUN: ptoas --pto-arch=a5 --pto-backend=vpto --vpto-emit-hivm-llvm %s -o - | FileCheck %s --check-prefix=VEC
// RUN: ptoas --pto-arch=a5 --pto-backend=vpto --vpto-march=dav-c310-cube --vpto-emit-hivm-llvm %s -o - | FileCheck %s --check-prefix=CUBE

module attributes {pto.target_arch = "a5"} {
  func.func @a5_low_precision_target_features(%src: !pto.ptr<!pto.hif8, gm>,
                                              %dst: !pto.ptr<!pto.hif8, ub>)
      attributes {pto.kernel_kind = #pto.kernel_kind<vector>} {
    %c0 = arith.constant 0 : i64
    %c1 = arith.constant 1 : i64
    %c32 = arith.constant 32 : i64
    %false = arith.constant false
    pto.copy_gm_to_ubuf %src, %dst, %c0, %c1, %c32, %c0, %c0, %false, %c0, %c0, %c0
      : !pto.ptr<!pto.hif8, gm>, !pto.ptr<!pto.hif8, ub>, i64, i64, i64, i64, i64, i1, i64, i64, i64
    return
  }
}

// VEC: attributes #0 = { "target-cpu"="dav-c310-vec" "target-features"="
// VEC-SAME: +F8e4m3
// VEC-SAME: +F8e5m2
// VEC-SAME: +Fp4e1m2x2
// VEC-SAME: +Fp4e2m1x2
// VEC-SAME: +dav-c310-vec"

// CUBE: attributes #0 = { "target-cpu"="dav-c310-cube" "target-features"="
// CUBE-SAME: +F8e4m3
// CUBE-SAME: +F8e5m2
// CUBE-SAME: +Fp4e1m2x2
// CUBE-SAME: +Fp4e2m1x2
// CUBE-SAME: +dav-c310-cube"
