// Guards composed low-precision vcvt helper lowering to Hivm LLVM.
// RUN: ptoas --pto-arch=a5 --pto-backend=vpto --vpto-emit-hivm-llvm %s -o - | FileCheck %s

module attributes {pto.target_arch = "a5"} {
  func.func @vcvt_low_precision_composed_fp8_helper(
      %src_fp8: !pto.ptr<f8E5M2, ub>,
      %dst0_f32: !pto.ptr<f32, ub>,
      %dst1_f32: !pto.ptr<f32, ub>)
      attributes {pto.kernel_kind = #pto.kernel_kind<vector>} {
    %c0 = arith.constant 0 : index
    %zero_fp8 = arith.constant 0.0 : f8E5M2
    pto.vecscope {
      %mask_b8 = pto.pset_b8 "PAT_ALL" : !pto.mask<b8>
      %mask_b32 = pto.pset_b32 "PAT_ALL" : !pto.mask<b32>
      %loaded = pto.vlds %src_fp8[%c0] {dist = "UNPK_B8"} : !pto.ptr<f8E5M2, ub> -> !pto.vreg<256xf8E5M2>
      %zero_vec = pto.vdup %zero_fp8, %mask_b8 : f8E5M2, !pto.mask<b8> -> !pto.vreg<256xf8E5M2>
      %low, %high = pto.vintlv %loaded, %zero_vec : !pto.vreg<256xf8E5M2>, !pto.vreg<256xf8E5M2> -> !pto.vreg<256xf8E5M2>, !pto.vreg<256xf8E5M2>
      %out0 = pto.vcvt %low, %mask_b8 {part = "P0"} : !pto.vreg<256xf8E5M2>, !pto.mask<b8> -> !pto.vreg<64xf32>
      %out1 = pto.vcvt %high, %mask_b8 {part = "P0"} : !pto.vreg<256xf8E5M2>, !pto.mask<b8> -> !pto.vreg<64xf32>
      pto.vsts %out0, %dst0_f32[%c0], %mask_b32 : !pto.vreg<64xf32>, !pto.ptr<f32, ub>, !pto.mask<b32>
      pto.vsts %out1, %dst1_f32[%c0], %mask_b32 : !pto.vreg<64xf32>, !pto.ptr<f32, ub>, !pto.mask<b32>
    }
    return
  }
}

// CHECK-LABEL: define void @vcvt_low_precision_composed_fp8_helper(
// CHECK: [[MASK_B8:%[0-9]+]] = call <256 x i1> @llvm.hivm.pset.b8(i32 0)
// CHECK: [[MASK_B32:%[0-9]+]] = call <256 x i1> @llvm.hivm.pset.b32(i32 0)
// CHECK: [[LOAD:%[0-9]+]] = call <256 x i8> @llvm.hivm.vldsx1.v256e5m2(ptr addrspace(6) {{.*}}, i32 0, i32 13, i32 0)
// CHECK: [[ZERO:%[0-9]+]] = call <256 x i8> @llvm.hivm.vdups.v256e5m2.z(i8 0, <256 x i1> [[MASK_B8]], i32 1)
// CHECK: [[PAIR:%[0-9]+]] = call { <256 x i8>, <256 x i8> } @llvm.hivm.vintlv.v256e5m2(<256 x i8> [[LOAD]], <256 x i8> [[ZERO]])
// CHECK: [[LOW:%[0-9]+]] = extractvalue { <256 x i8>, <256 x i8> } [[PAIR]], 0
// CHECK: [[HIGH:%[0-9]+]] = extractvalue { <256 x i8>, <256 x i8> } [[PAIR]], 1
// CHECK: call <64 x float> @llvm.hivm.vcvtff.f8e5m22f32.x(<256 x i8> [[LOW]], <256 x i1> [[MASK_B8]], i32 0)
// CHECK: call <64 x float> @llvm.hivm.vcvtff.f8e5m22f32.x(<256 x i8> [[HIGH]], <256 x i1> [[MASK_B8]], i32 0)
// CHECK: call void @llvm.hivm.vstsx1.v64f32({{.*}}, ptr addrspace(6) {{.*}}, i32 0, i32 2, i32 0, <256 x i1> [[MASK_B32]])
