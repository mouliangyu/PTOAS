// Guards VPTO vector authoring for supported low-precision element types.
// RUN: ptoas --pto-arch=a5 --pto-backend=vpto %s -o - 2>&1 | FileCheck %s

module attributes {pto.target_arch = "a5"} {
  func.func @vpto_low_precision_fp8_vector_authoring_positive(
      %src_ub_fp8: !pto.ptr<f8E5M2, ub>,
      %dst_ub_fp8: !pto.ptr<f8E5M2, ub>,
      %lane_bits: !pto.vreg<256xi8>)
      attributes {pto.kernel_kind = #pto.kernel_kind<vector>} {
    %c0 = arith.constant 0 : index
    pto.vecscope {
      %mask = pto.pset_b8 "PAT_ALL" : !pto.mask<b8>
      %loaded = pto.vlds %src_ub_fp8[%c0] : !pto.ptr<f8E5M2, ub> -> !pto.vreg<256xf8E5M2>
      %sel = pto.vselr %loaded, %lane_bits : !pto.vreg<256xf8E5M2>, !pto.vreg<256xi8> -> !pto.vreg<256xf8E5M2>
      pto.vsts %sel, %dst_ub_fp8[%c0], %mask : !pto.vreg<256xf8E5M2>, !pto.ptr<f8E5M2, ub>, !pto.mask<b8>
    }
    return
  }

  func.func @vpto_low_precision_fp4_vector_authoring_positive(
      %src_ub_fp4: !pto.ptr<!pto.f4E2M1x2, ub>,
      %dst_ub_fp4: !pto.ptr<!pto.f4E2M1x2, ub>,
      %lane_bits: !pto.vreg<256xi8>)
      attributes {pto.kernel_kind = #pto.kernel_kind<vector>} {
    %c0 = arith.constant 0 : index
    pto.vecscope {
      %mask = pto.pset_b8 "PAT_ALL" : !pto.mask<b8>
      %loaded = pto.vlds %src_ub_fp4[%c0] : !pto.ptr<!pto.f4E2M1x2, ub> -> !pto.vreg<256x!pto.f4E2M1x2>
      %bytes = pto.vbitcast %loaded : !pto.vreg<256x!pto.f4E2M1x2> -> !pto.vreg<256xui8>
      %roundtrip = pto.vbitcast %bytes : !pto.vreg<256xui8> -> !pto.vreg<256x!pto.f4E2M1x2>
      %sel = pto.vselr %roundtrip, %lane_bits : !pto.vreg<256x!pto.f4E2M1x2>, !pto.vreg<256xi8> -> !pto.vreg<256x!pto.f4E2M1x2>
      pto.vsts %sel, %dst_ub_fp4[%c0], %mask : !pto.vreg<256x!pto.f4E2M1x2>, !pto.ptr<!pto.f4E2M1x2, ub>, !pto.mask<b8>
    }
    return
  }
}

// CHECK-LABEL: func.func @vpto_low_precision_fp8_vector_authoring_positive
// CHECK-SAME: %{{.*}}: !pto.ptr<f8E5M2, ub>, %{{.*}}: !pto.ptr<f8E5M2, ub>, %{{.*}}: !pto.vreg<256xi8>)
// CHECK: pto.vecscope
// CHECK: pto.pset_b8 "PAT_ALL" : !pto.mask<b8>
// CHECK: pto.vlds %{{.*}}[%{{.*}}] : !pto.ptr<f8E5M2, ub> -> !pto.vreg<256xf8E5M2>
// CHECK: pto.vselr %{{.*}}, %{{.*}} : !pto.vreg<256xf8E5M2>, !pto.vreg<256xi8> -> !pto.vreg<256xf8E5M2>
// CHECK: pto.vsts %{{.*}}, %{{.*}}[%{{.*}}], %{{.*}} : !pto.vreg<256xf8E5M2>, !pto.ptr<f8E5M2, ub>, !pto.mask<b8>

// CHECK-LABEL: func.func @vpto_low_precision_fp4_vector_authoring_positive
// CHECK-SAME: %{{.*}}: !pto.ptr<!pto.f4E2M1x2, ub>, %{{.*}}: !pto.ptr<!pto.f4E2M1x2, ub>, %{{.*}}: !pto.vreg<256xi8>)
// CHECK: pto.vecscope
// CHECK: pto.pset_b8 "PAT_ALL" : !pto.mask<b8>
// CHECK: pto.vlds %{{.*}}[%{{.*}}] : !pto.ptr<!pto.f4E2M1x2, ub> -> !pto.vreg<256x!pto.f4E2M1x2>
// CHECK: pto.vbitcast %{{.*}} : !pto.vreg<256x!pto.f4E2M1x2> -> !pto.vreg<256xui8>
// CHECK: pto.vbitcast %{{.*}} : !pto.vreg<256xui8> -> !pto.vreg<256x!pto.f4E2M1x2>
// CHECK: pto.vselr %{{.*}}, %{{.*}} : !pto.vreg<256x!pto.f4E2M1x2>, !pto.vreg<256xi8> -> !pto.vreg<256x!pto.f4E2M1x2>
// CHECK: pto.vsts %{{.*}}, %{{.*}}[%{{.*}}], %{{.*}} : !pto.vreg<256x!pto.f4E2M1x2>, !pto.ptr<!pto.f4E2M1x2, ub>, !pto.mask<b8>
