// Guards low-precision vreg types remaining legal in VPTO IR signatures.
// RUN: ptoas --pto-arch=a5 --pto-backend=vpto %s -o - 2>&1 | FileCheck %s

module attributes {pto.target_arch = "a5"} {
  func.func @vreg_low_precision_type_legal(
      %arg0: !pto.vreg<256x!pto.hif8>,
      %arg1: !pto.vreg<256xf8E5M2>,
      %arg2: !pto.vreg<256x!pto.f4E2M1x2>)
      -> (!pto.vreg<256x!pto.hif8>, !pto.vreg<256xf8E5M2>, !pto.vreg<256x!pto.f4E2M1x2>)
      attributes {pto.kernel_kind = #pto.kernel_kind<vector>} {
    return %arg0, %arg1, %arg2 : !pto.vreg<256x!pto.hif8>, !pto.vreg<256xf8E5M2>, !pto.vreg<256x!pto.f4E2M1x2>
  }
}

// CHECK-LABEL: func.func @vreg_low_precision_type_legal(
// CHECK-SAME: %arg0: !pto.vreg<256x!pto.hif8>
// CHECK-SAME: %arg1: !pto.vreg<256xf8E5M2>
// CHECK-SAME: %arg2: !pto.vreg<256x!pto.f4E2M1x2>
// CHECK-SAME: -> (!pto.vreg<256x!pto.hif8>, !pto.vreg<256xf8E5M2>, !pto.vreg<256x!pto.f4E2M1x2>)
