// Guards composed low-precision vcvt helper authoring in VPTO IR.
// RUN: ptoas --pto-arch=a5 --pto-backend=vpto %s -o - 2>&1 | FileCheck %s

module attributes {pto.target_arch = "a5"} {
  func.func @vcvt_low_precision_composed_fp8_helper_authoring(
      %src_fp8: !pto.ptr<f8E5M2, ub>,
      %dst0_f32: !pto.ptr<f32, ub>,
      %dst1_f32: !pto.ptr<f32, ub>)
      attributes {pto.kernel_kind = #pto.kernel_kind<vector>} {
    %c0 = arith.constant 0 : index
    %zero_fp8 = arith.constant 0.0 : f8E5M2
    pto.vecscope {
      %mask_b8 = pto.pset_b8 "PAT_ALL" : !pto.mask<b8>
      %mask_b32 = pto.pset_b32 "PAT_ALL" : !pto.mask<b32>
      %loaded = pto.vlds %src_fp8[%c0] {dist = "UNPK_B8"} : !pto.ptr<f8E5M2, ub> -> !pto.vreg<256xf8E5M2>
      %zero_vec = pto.vdup %zero_fp8, %mask_b8 : f8E5M2, !pto.mask<b8> -> !pto.vreg<256xf8E5M2>
      %low, %high = pto.vintlv %loaded, %zero_vec : !pto.vreg<256xf8E5M2>, !pto.vreg<256xf8E5M2> -> !pto.vreg<256xf8E5M2>, !pto.vreg<256xf8E5M2>
      %out0 = pto.vcvt %low, %mask_b8 {part = "P0"} : !pto.vreg<256xf8E5M2>, !pto.mask<b8> -> !pto.vreg<64xf32>
      %out1 = pto.vcvt %high, %mask_b8 {part = "P0"} : !pto.vreg<256xf8E5M2>, !pto.mask<b8> -> !pto.vreg<64xf32>
      pto.vsts %out0, %dst0_f32[%c0], %mask_b32 : !pto.vreg<64xf32>, !pto.ptr<f32, ub>, !pto.mask<b32>
      pto.vsts %out1, %dst1_f32[%c0], %mask_b32 : !pto.vreg<64xf32>, !pto.ptr<f32, ub>, !pto.mask<b32>
    }
    return
  }
}

// CHECK-LABEL: func.func @vcvt_low_precision_composed_fp8_helper_authoring(
// CHECK: %{{.*}} = arith.constant 0.000000e+00 : f8E5M2
// CHECK: %{{.*}} = pto.pset_b8 "PAT_ALL" : !pto.mask<b8>
// CHECK: %{{.*}} = pto.pset_b32 "PAT_ALL" : !pto.mask<b32>
// CHECK: %{{.*}} = pto.vlds %{{.*}}[%{{.*}}] {dist = "UNPK_B8"} : !pto.ptr<f8E5M2, ub> -> !pto.vreg<256xf8E5M2>
// CHECK: %{{.*}} = pto.vdup %{{.*}}, %{{.*}} : f8E5M2, !pto.mask<b8> -> !pto.vreg<256xf8E5M2>
// CHECK: %{{.*}}, %{{.*}} = pto.vintlv %{{.*}}, %{{.*}} : !pto.vreg<256xf8E5M2>, !pto.vreg<256xf8E5M2> -> !pto.vreg<256xf8E5M2>, !pto.vreg<256xf8E5M2>
// CHECK: %{{.*}} = pto.vcvt %{{.*}}, %{{.*}} {part = "P0"} : !pto.vreg<256xf8E5M2>, !pto.mask<b8> -> !pto.vreg<64xf32>
// CHECK: %{{.*}} = pto.vcvt %{{.*}}, %{{.*}} {part = "P0"} : !pto.vreg<256xf8E5M2>, !pto.mask<b8> -> !pto.vreg<64xf32>
// CHECK: pto.vsts %{{.*}}, %{{.*}}[%{{.*}}], %{{.*}} : !pto.vreg<64xf32>, !pto.ptr<f32, ub>, !pto.mask<b32>
