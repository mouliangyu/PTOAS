// RUN: not ptoas --pto-arch=a5 %s -o - 2>&1 | FileCheck %s

module attributes {"pto.target_arch" = "a5"} {
  func.func @acc_store_verify_invalid_atomic(%src: !pto.ptr<f32, acc>,
                                             %dst: !pto.ptr<f32, mat>) {
    %c16_i64 = arith.constant 16 : i64
    %c32_i64 = arith.constant 32 : i64

    pto.acc_store %src, %dst, %c16_i64, %c16_i64, %c16_i64, %c32_i64,
      atomic(type = f32, op = add)
      : !pto.ptr<f32, acc>, !pto.ptr<f32, mat>, i64, i64, i64, i64

    return
  }
}

// CHECK: atomic is only supported for acc_store_gm
