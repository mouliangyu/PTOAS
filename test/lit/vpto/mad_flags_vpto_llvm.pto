// RUN: ( mkdir -p %T && ptoas --pto-arch=a5 --pto-backend=vpto %s -o %t --mlir-print-ir-after=convert-func-to-llvm 2>&1 || true ) | FileCheck %s

module attributes {pto.target_arch = "a5", pto.kernel_kind = #pto.kernel_kind<cube>} {
  func.func @mad_flags() attributes {pto.aicore} {
    %c0 = arith.constant 0 : i64
    %c4 = arith.constant 4 : i64
    %c16 = arith.constant 16 : i64
    %c32 = arith.constant 32 : i64
    %c48 = arith.constant 48 : i64
    %lhs = pto.castptr %c0 : i64 -> !pto.ptr<f16, left>
    %rhs = pto.castptr %c0 : i64 -> !pto.ptr<f16, right>
    %dst = pto.castptr %c0 : i64 -> !pto.ptr<f32, acc>
    %bias = pto.castptr %c4 : i64 -> !pto.ptr<f32, bias>

    pto.mad %lhs, %rhs, %dst, %c16, %c48, %c32
      : !pto.ptr<f16, left>, !pto.ptr<f16, right>, !pto.ptr<f32, acc>, i64, i64, i64
    pto.mad_acc %lhs, %rhs, %dst, %c16, %c48, %c32 {unit_flag_ctrl = 2 : i32, disable_gemv = false}
      : !pto.ptr<f16, left>, !pto.ptr<f16, right>, !pto.ptr<f32, acc>, i64, i64, i64
    pto.mad_bias %lhs, %rhs, %dst, %bias, %c16, %c48, %c32
      : !pto.ptr<f16, left>, !pto.ptr<f16, right>, !pto.ptr<f32, acc>, !pto.ptr<f32, bias>, i64, i64, i64
    return
  }
}

// CHECK-LABEL: llvm.func @mad_flags_mix_aic
// CHECK: llvm.call @llvm.hivm.MAD.f162f32.c310
