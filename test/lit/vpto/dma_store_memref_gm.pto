// RUN: not ptoas --pto-arch=a5 --mlir-print-ir-before-all %s -o /dev/null 2>&1 | FileCheck %s

module attributes {pto.target_arch = "a5"} {
  func.func @dma_store_memref_gm_probe(%src: memref<?xf16, #pto.address_space<gm>>,
                                       %ub: memref<?xf16, #pto.address_space<vec>>,
                                       %dst: memref<?xf16, #pto.address_space<gm>>)
      attributes {pto.aicore} {
    %c0 = arith.constant 0 : i64
    %c1 = arith.constant 1 : i64
    %c128 = arith.constant 128 : i64
    %false = arith.constant false

    pto.copy_gm_to_ubuf %src, %ub, %c0, %c1, %c128, %c0, %c0, %false, %c0, %c128, %c128
      : memref<?xf16, #pto.address_space<gm>>, memref<?xf16, #pto.address_space<vec>>, i64, i64, i64, i64, i64, i1, i64, i64, i64
    pto.dma_load %src, %ub, %c0, %c128
      nburst(%c1, %c128, %c128)
      : memref<?xf16, #pto.address_space<gm>>, memref<?xf16, #pto.address_space<vec>>, i64, i64, i64, i64, i64
    pto.copy_ubuf_to_gm %ub, %dst, %c0, %c1, %c128, %c0, %c128, %c128
      : memref<?xf16, #pto.address_space<vec>>, memref<?xf16, #pto.address_space<gm>>, i64, i64, i64, i64, i64, i64
    pto.dma_store %ub, %dst, %c128
      nburst(%c1, %c128, %c128)
      : memref<?xf16, #pto.address_space<vec>>, memref<?xf16, #pto.address_space<gm>>, i64, i64, i64, i64
    return
  }
}

// CHECK: pto.copy_gm_to_ubuf
// CHECK-SAME: memref<?xf16, #pto.address_space<gm>>, memref<?xf16, #pto.address_space<vec>>
// CHECK: pto.dma_load
// CHECK-SAME: memref<?xf16, #pto.address_space<gm>>, memref<?xf16, #pto.address_space<vec>>
// CHECK: pto.copy_ubuf_to_gm
// CHECK-SAME: memref<?xf16, #pto.address_space<vec>>, memref<?xf16, #pto.address_space<gm>>
// CHECK: pto.dma_store
// CHECK-SAME: memref<?xf16, #pto.address_space<vec>>, memref<?xf16, #pto.address_space<gm>>
// CHECK-NOT: pointer-like buffer type
