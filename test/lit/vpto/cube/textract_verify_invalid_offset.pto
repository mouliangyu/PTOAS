// Negative: A5 textract Mat->Left with non-zero indexRow should be rejected.
// Offset extraction for cube path is not yet supported.
//
// RUN: not ptoas --pto-arch=a5 --pto-backend=vpto %s -o - 2>&1 | FileCheck %s

// CHECK: expects A5 mat->left/right textract to have indexRow=0 and indexCol=0

module attributes {pto.target_arch = "a5", pto.kernel_kind = #pto.kernel_kind<cube>} {
  func.func @TEXTRACT_M2L_OFFSET_REJECTED() attributes {pto.aicore} {
    %c4 = arith.constant 4 : index
    %c0 = arith.constant 0 : index
    %src = pto.alloc_tile
      : !pto.tile_buf<loc=mat, dtype=f16, rows=32, cols=32, v_row=32, v_col=32,
                       blayout=row_major, slayout=col_major, fractal=512, pad=0>
    %dst = pto.alloc_tile
      : !pto.tile_buf<loc=left, dtype=f16, rows=16, cols=16, v_row=16, v_col=16,
                       blayout=col_major, slayout=row_major, fractal=512, pad=0>

    pto.textract ins(%src, %c4, %c0 : !pto.tile_buf<loc=mat, dtype=f16, rows=32, cols=32, v_row=32, v_col=32,
                                     blayout=row_major, slayout=col_major, fractal=512, pad=0>, index, index)
                outs(%dst : !pto.tile_buf<loc=left, dtype=f16, rows=16, cols=16, v_row=16, v_col=16,
                                           blayout=col_major, slayout=row_major, fractal=512, pad=0>)
    return
  }
}