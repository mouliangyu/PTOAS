// Guard: a top-level uncovered segment containing only MAT-local tile ops is
// ambiguous and must fail-fast instead of silently defaulting to a section kind.
// RUN: not ptoas --pto-arch=a5 --pto-backend=vpto --emit-pto-ir %s -o - 2>&1 | FileCheck %s

module attributes {pto.target_arch = "a5"} {
  func.func @ambiguous_mat_only(
      %src: !pto.ptr<bf16, gm>) attributes {pto.kernel} {
    %c0 = arith.constant 0 : index
    %c1 = arith.constant 1 : index
    %c16 = arith.constant 16 : index
    %c128 = arith.constant 128 : index
    %src_view = pto.make_tensor_view %src, shape = [%c16, %c128], strides = [%c128, %c1] : !pto.tensor_view<?x?xbf16>
    %src_part = pto.partition_view %src_view, offsets = [%c0, %c0], sizes = [%c16, %c128] : !pto.tensor_view<?x?xbf16> -> !pto.partition_tensor_view<16x128xbf16>
    %tile = pto.alloc_tile : !pto.tile_buf<loc=mat, dtype=bf16, rows=16, cols=128, v_row=16, v_col=128, blayout=col_major, slayout=row_major, fractal=512, pad=0>

    pto.tload ins(%src_part : !pto.partition_tensor_view<16x128xbf16>)
             outs(%tile : !pto.tile_buf<loc=mat, dtype=bf16, rows=16, cols=128, v_row=16, v_col=128, blayout=col_major, slayout=row_major, fractal=512, pad=0>)
    return
  }
}

// CHECK: uncovered top-level TileOp segment whose section kind cannot be inferred uniquely
// CHECK: ambiguous TileOp(s): 'pto.tload'
