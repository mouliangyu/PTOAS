// Guards mixed-backend fatobj output preserving the logical EmitC entry name
// and embedding the Bisheng-generated host launch helper in the child fatobj.
// RUN: ptoas --pto-arch=a5 %s -o %t.o
// RUN: readelf -Ws %t.o | FileCheck %s

module attributes {pto.target_arch = "a5"} {
  module attributes {pto.backend = "emitc"} {
    func.func @emitc_entry(%arg0: memref<16xf32>, %arg1: f32)
        attributes {pto.aicore, pto.entry} {
      return
    }

    func.func @emitc_helper(%arg0: memref<16xf32>)
        attributes {pto.internal.non_entry = true} {
      return
    }
  }

  module attributes {
    pto.backend = "vpto",
    pto.kernel_kind = #pto.kernel_kind<vector>
  } {
    func.func @vpto_device() attributes {pto.aicore} {
      return
    }
  }
}

// CHECK: LOCAL  HIDDEN {{.*}} __cce_rtKernelLaunchWithFlagV2
// CHECK: GLOBAL DEFAULT {{.*}} emitc_entry
