// RUN: not ptoas --pto-arch=a3 %s 2>&1 | FileCheck %s

// Test TSTORE_FP invalid dtype combination - should fail because ACC must be f32 or i32
// NOTE: A5 verifier does not check element type, so this test uses A3 where the check exists.

module attributes {pto.target_arch = "a3"} {
 func.func @tstore_fp_invalid_dtype(%dst_gm: !pto.ptr<f16>) attributes {pto.kernel_kind = #pto.kernel_kind<cube>, pto.aicore} {
 %c1 = arith.constant 1 : index
 %c32 = arith.constant 32 : index
 %c0_idx = arith.constant 0 : index

 // This should fail - ACC with f16 is not supported for TSTORE_FP (requires f32/i32)
 %acc_tile = pto.alloc_tile : !pto.tile_buf<acc, 16x32xf16, blayout=col_major, slayout=row_major>

 // Allocate FP (scaling) buffer
 %fp_tile = pto.alloc_tile : !pto.tile_buf<scaling, 1x32xf16>

 // Construct destination partition view
 %tv = pto.make_tensor_view %dst_gm, shape = [%c1, %c32], strides = [%c32, %c1] : !pto.tensor_view<?x?xf16>
 %sv = pto.partition_view %tv, offsets = [%c0_idx, %c0_idx], sizes = [%c1, %c32] : !pto.tensor_view<?x?xf16> -> !pto.partition_tensor_view<1x32xf16>

 // This should NOT match TSTORE_FP template because ACC dtype is not f32
 pto.tstore_fp ins(%acc_tile, %fp_tile : !pto.tile_buf<acc, 16x32xf16, blayout=col_major, slayout=row_major>, !pto.tile_buf<scaling, 1x32xf16>)
               outs(%sv : !pto.partition_tensor_view<1x32xf16>)

 pto.barrier #pto.pipe<PIPE_ALL>
 return
 }
}

// CHECK: expects src to have element type f32