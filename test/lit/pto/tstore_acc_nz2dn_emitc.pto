// RUN: ptoas --pto-arch=a5 %s 2>&1 | FileCheck %s

// Test TSTORE.ACC NZ2DN template - ACC → GM with NZ2DN layout conversion

module attributes {pto.target_arch = "a5"} {
 func.func @tstore_acc_nz2dn_f32(%src_acc: !pto.ptr<f32, l0c>, %dst_gm: !pto.ptr<f32, gm>) attributes {pto.kernel_kind = #pto.kernel_kind<cube>, pto.aicore} {
  %c0 = arith.constant 0 : i64
  %c16 = arith.constant 16 : i64
  %c32 = arith.constant 32 : i64

  // Allocate ACC buffer
  %acc_tile = pto.alloc_tile addr = %c0 : !pto.tile_buf<acc, 16x32xf32, blayout=col_major, slayout=row_major>

  // Get pointer from tile
  %acc_ptr = pto.tile_buf_addr %acc_tile : !pto.tile_buf<acc, 16x32xf32, blayout=col_major, slayout=row_major> -> !pto.ptr<f32, l0c>

  // Use mte_l0c_gm for NZ2DN
  pto.mte_l0c_gm %acc_ptr, %dst_gm, %c16, %c32, %c32, %c32, %c0, %c0, nz2dn
   : !pto.ptr<f32, l0c>, !pto.ptr<f32, gm>, i64, i64, i64, i64, i64, i64

  pto.barrier #pto.pipe<PIPE_ALL>
  return
 }
}

// CHECK-LABEL: tstore_acc_nz2dn_f32
// CHECK: pto.mte_l0c_gm
// CHECK: nz2dn