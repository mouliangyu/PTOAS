// Guards the EmitC fixup that sinks tile.data() reads past TASSIGN for
// tile-like emitc.variable values.
// RUN: ptoas --pto-arch=a5 --mlir-print-ir-after='*' %s -o /dev/null 2>&1 | FileCheck %s

module attributes {pto.target_arch = "a5", pto.kernel_kind = #pto.kernel_kind<vector>} {
  func.func @kernel(%arg0: i64) {
    %0 = pto.alloc_tile addr = %arg0 : !pto.tile_buf<vec, 1x16xf32>
    %1 = pto.tile_buf_addr %0 : !pto.tile_buf<vec, 1x16xf32> -> !pto.ptr<f32, ub>
    func.call @sink_ptr(%1) : (!pto.ptr<f32, ub>) -> ()
    return
  }

  func.func private @sink_ptr(%arg0: !pto.ptr<f32, ub>) {
    return
  }
}

// CHECK-LABEL: // -----// IR Dump After {anonymous}::EmitPTOManualPass () //----- //
// CHECK-LABEL: emitc.func @kernel
// CHECK: %[[TILE:[0-9]+]] = "emitc.variable"
// CHECK-NEXT: %[[ADDR:[0-9]+]] = emitc.cast %arg0
// CHECK-NEXT: emitc.call_opaque "TASSIGN"(%[[TILE]], %[[ADDR]])
// CHECK: emitc.call_opaque "PTOAS__TILE_DATA"(%[[TILE]])
// CHECK-NEXT: emitc.call @sink_ptr
