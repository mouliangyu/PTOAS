// RUN: ptoas --pto-arch=a5 --pto-backend=vpto --emit-vpto --mlir-print-ir-before=vpto-expand-wrapper-ops %s -o /dev/null 2>&1 | FileCheck %s --check-prefix=ROUNDTRIP

// Test TSTORE.ACC NZ2NZ template - ACC → GM with NZ2NZ (no conversion, fractal to fractal)

module attributes {pto.target_arch = "a5", pto.kernel_kind = #pto.kernel_kind<cube>} {
 func.func @tstore_acc_nz2nz_f32(%src_acc: !pto.ptr<f32, l0c>, %dst_gm: !pto.ptr<f32, gm>) {
  %c0 = arith.constant 0 : i64
  %c16 = arith.constant 16 : i64
  %c32 = arith.constant 32 : i64

  // Use mte_l0c_gm for NZ2NZ
  pto.mte_l0c_gm %src_acc, %dst_gm, %c16, %c32, %c32, %c32, %c0, %c0, nz2nz
   : !pto.ptr<f32, l0c>, !pto.ptr<f32, gm>, i64, i64, i64, i64, i64, i64

  return
 }
}

// ROUNDTRIP-LABEL: func.func @tstore_acc_nz2nz_f32(
// ROUNDTRIP: pto.mte_l0c_gm
// ROUNDTRIP: nz2nz