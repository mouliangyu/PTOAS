// Guards default entry inference when a multi-function module has one
// user-facing function and helper definitions marked pto.internal.non_entry.
// RUN: ptoas %s | FileCheck %s

module {
  func.func @kernel(%arg0: !pto.ptr<f32>, %arg1: i32) {
    func.call @helper(%arg1) : (i32) -> ()
    return
  }

  func.func @helper(%arg0: i32) attributes {pto.internal.non_entry = true} {
    return
  }
}

// CHECK-LABEL: extern "C" AICORE void helper(
// CHECK-LABEL: __global__ AICORE void kernel(
// CHECK: helper(
