// Guards alloc_tile low-precision arch and backend gating.
// RUN: ptoas --pto-arch=a5 --pto-backend=vpto %s -o - 2>&1 | FileCheck %s --check-prefix=A5-VPTO
// RUN: not ptoas --pto-arch=a5 %s -o - 2>&1 | FileCheck %s --check-prefix=A5-EMITC
// RUN: not ptoas --pto-arch=a3 --pto-backend=vpto %s -o - 2>&1 | FileCheck %s --check-prefix=A3-VPTO

module {
  func.func @alloc_low_precision_tiles() {
    %hif8 = pto.alloc_tile
      : !pto.tile_buf<loc=vec, dtype=!pto.hif8, rows=16, cols=64, v_row=16, v_col=64,
                      blayout=row_major, slayout=none_box, fractal=512, pad=0>
    %fp4 = pto.alloc_tile
      : !pto.tile_buf<loc=vec, dtype=!pto.f4E1M2x2, rows=16, cols=64, v_row=16, v_col=64,
                      blayout=row_major, slayout=none_box, fractal=512, pad=0>
    %fp8 = pto.alloc_tile
      : !pto.tile_buf<loc=vec, dtype=f8E4M3FN, rows=16, cols=64, v_row=16, v_col=64,
                      blayout=row_major, slayout=none_box, fractal=512, pad=0>
    return
  }
}

// A5-VPTO: func.func @alloc_low_precision_tiles
// A5-VPTO-NOT: error:

// A5-EMITC: error: result dtype '!pto.hif8' requires --pto-backend=vpto on A5; emitc does not support low-precision alloc_tile yet

// A3-VPTO: error: 'pto.alloc_tile' op result dtype '!pto.hif8' is only supported by pto.alloc_tile on A5
