// Guards tile data-movement rejection for unsupported low-precision dtypes.
// RUN: not ptoas --pto-arch=a5 --pto-backend=vpto --emit-vpto %s -o - 2>&1 | FileCheck %s --check-prefix=A5
// RUN: not ptoas --pto-arch=a3 --pto-backend=vpto %s 2>&1 | FileCheck %s --check-prefix=A3

module {
  func.func @low_precision_tprefetch_arch_scope(
      %src_f4 : !pto.partition_tensor_view<16x64x!pto.f4E2M1x2>,
      %dst_f4 : !pto.tile_buf<loc=vec, dtype=!pto.f4E2M1x2, rows=16, cols=64, v_row=16, v_col=64, blayout=row_major, slayout=none_box, fractal=512, pad=0>) {
    pto.tprefetch ins(%src_f4 : !pto.partition_tensor_view<16x64x!pto.f4E2M1x2>)
                  outs(%dst_f4 : !pto.tile_buf<loc=vec, dtype=!pto.f4E2M1x2, rows=16, cols=64, v_row=16, v_col=64, blayout=row_major, slayout=none_box, fractal=512, pad=0>)
    return
  }
}

// A5: error: low-precision dtype operand(s) [#0=!pto.f4E2M1x2, #1=!pto.f4E2M1x2] are not supported by ExpandTileOp tilelang template specialization yet for target a5

// A3: error: 'pto.tprefetch' op dst: dtype '!pto.f4E2M1x2' is not supported by this op yet
