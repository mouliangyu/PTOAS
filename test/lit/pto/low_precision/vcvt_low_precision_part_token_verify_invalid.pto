// Guards vcvt rejection of unsupported low-precision part tokens.
// RUN: not ptoas --pto-arch=a5 --pto-backend=vpto %s 2>&1 | FileCheck %s

// CHECK: error: custom op 'pto.vcvt' part has unsupported value 'MID'

module attributes {pto.target_arch = "a5"} {
  func.func @vcvt_low_precision_rejects_bad_part_token(
      %src_fp8: !pto.vreg<256xf8E5M2>)
      attributes {pto.kernel_kind = #pto.kernel_kind<vector>} {
    pto.vecscope {
      %mask_b8 = pto.pset_b8 "PAT_ALL" : !pto.mask<b8>
      %bad = pto.vcvt %src_fp8, %mask_b8 {part = "MID"} : !pto.vreg<256xf8E5M2>, !pto.mask<b8> -> !pto.vreg<64xf32>
    }
    return
  }
}
