// Guards vcvt rejection of unsupported low-precision round-mode tokens.
// RUN: not ptoas --pto-arch=a5 --pto-backend=vpto %s 2>&1 | FileCheck %s

// CHECK: error: custom op 'pto.vcvt' rnd has unsupported value 'BAD'

module attributes {pto.target_arch = "a5"} {
  func.func @vcvt_low_precision_rejects_bad_round_token(
      %src_f32: !pto.vreg<64xf32>)
      attributes {pto.kernel_kind = #pto.kernel_kind<vector>} {
    pto.vecscope {
      %mask_b32 = pto.pset_b32 "PAT_ALL" : !pto.mask<b32>
      %bad = pto.vcvt %src_f32, %mask_b32 {rnd = "BAD", sat = "SAT", part = "P0"} : !pto.vreg<64xf32>, !pto.mask<b32> -> !pto.vreg<256x!pto.hif8>
    }
    return
  }
}
