// RUN: ptoas --pto-arch=a5 %s --emit-c --tile-op-expand 2>&1 | FileCheck %s

// Test TSTORE_FP template - ACC → GM with fixed-point dequantization
// NOTE: pto.tstore_fp DSL surface not yet supported, this test is pending

module attributes {pto.target_arch = "a5"} {
  func.func @tstore_fp_f32_f16(%src_acc: !pto.ptr<f32, l0c>, %fp_scale: !pto.ptr<f16, scaling>, %dst_gm: !pto.ptr<f16, gm>) attributes {pto.kernel_kind = #pto.kernel_kind<cube>, pto.aicore} {
    %c0 = arith.constant 0 : i64
    %c16 = arith.constant 16 : i64
    %c32 = arith.constant 32 : i64

    // Allocate ACC buffer
    %acc_tile = pto.alloc_tile addr = %c0 : !pto.tile_buf<acc, 16x32xf32, blayout=col_major, slayout=row_major, fractal=512>

    // Get pointer from tile
    %acc_ptr = pto.tile_buf_addr %acc_tile : !pto.tile_buf<acc, 16x32xf32, blayout=col_major, slayout=row_major, fractal=512> -> !pto.ptr<f32, l0c>

    // Use tstore_fp for fixed-point store with dequantization
    pto.tstore_fp %acc_ptr, %fp_scale, %dst_gm, nz2nd
      : !pto.ptr<f32, l0c>, !pto.ptr<f16, scaling>, !pto.ptr<f16, gm>, nz2nd_mode

    pto.barrier #pto.pipe<PIPE_ALL>
    return
  }
}

// CHECK-LABEL: tstore_fp_f32_f16
// CHECK: pto.tstore_fp
// CHECK: nz2nd