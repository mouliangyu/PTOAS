// RUN: ptoas --pto-arch=a3 %s 2>&1 | FileCheck %s

// Test TSTORE.MAT template - MAT (L1) → GM store using tstore DPS surface
// NOTE: A5 TSTORE only accepts VEC/ACC src, so this test uses A3 where MAT src is valid.

module attributes {pto.target_arch = "a3"} {
 func.func @tstore_mat_f16(%src: !pto.ptr<f16>, %dst: !pto.ptr<f16>) attributes {pto.kernel_kind = #pto.kernel_kind<cube>, pto.aicore} {
  %c0 = arith.constant 0 : index
  %c1 = arith.constant 1 : index
  %c16 = arith.constant 16 : index
  %c32 = arith.constant 32 : index

  %tv = pto.make_tensor_view %dst, shape = [%c16, %c32], strides = [%c32, %c1] : !pto.tensor_view<?x?xf16>
  %sv = pto.partition_view %tv, offsets = [%c0, %c0], sizes = [%c16, %c32] : !pto.tensor_view<?x?xf16> -> !pto.partition_tensor_view<16x32xf16>

  // Allocate MAT buffer in L1
  %mat_tile = pto.alloc_tile : !pto.tile_buf<mat, 16x32xf16, blayout=col_major, slayout=row_major>

  // Use tstore for MAT → GM store
  pto.tstore ins(%mat_tile : !pto.tile_buf<mat, 16x32xf16, blayout=col_major, slayout=row_major>)
             outs(%sv : !pto.partition_tensor_view<16x32xf16>)

  pto.barrier #pto.pipe<PIPE_ALL>
  return
 }
}

// CHECK-LABEL: tstore_mat_f16
// CHECK: TSTORE