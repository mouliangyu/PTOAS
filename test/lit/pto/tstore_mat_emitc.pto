// RUN: ptoas --pto-arch=a5 %s 2>&1 | FileCheck %s

// Test TSTORE.MAT template - MAT (L1) → GM store
// NOTE: pto.mte_l1_gm DSL surface not yet supported, this test is pending

module attributes {pto.target_arch = "a5"} {
 func.func @tstore_mat_f16(%src_l1: !pto.ptr<f16, l1>, %dst_gm: !pto.ptr<f16, gm>) attributes {pto.kernel_kind = #pto.kernel_kind<cube>, pto.aicore} {
  %c0 = arith.constant 0 : i64
  %c16 = arith.constant 16 : i64
  %c32 = arith.constant 32 : i64

  // Allocate MAT buffer in L1
  %mat_tile = pto.alloc_tile addr = %c0 : !pto.tile_buf<mat, 16x32xf16, blayout=col_major, slayout=row_major>

  // Get pointer from tile
  %mat_ptr = pto.tile_buf_addr %mat_tile : !pto.tile_buf<mat, 16x32xf16, blayout=col_major, slayout=row_major> -> !pto.ptr<f16, l1>

  // Use mte_l1_gm for MAT store
  pto.mte_l1_gm %mat_ptr, %dst_gm, %c16, %c32, %c32, %c32, %c0, %c0
   : !pto.ptr<f16, l1>, !pto.ptr<f16, gm>, i64, i64, i64, i64, i64, i64

  pto.barrier #pto.pipe<PIPE_ALL>
  return
 }
}

// CHECK-LABEL: tstore_mat_f16
// CHECK: pto.mte_l1_gm