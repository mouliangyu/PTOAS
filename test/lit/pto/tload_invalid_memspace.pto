// RUN: not ptoas --pto-arch=a5 %s 2>&1 | FileCheck %s

// Test TLOAD.MAT invalid memory space - should fail because UB is not MAT

module attributes {pto.target_arch = "a5"} {
 func.func @tload_invalid_memspace(%src_gm: !pto.ptr<f16, gm>, %dst_ub: !pto.ptr<f16, ub>) attributes {pto.kernel_kind = #pto.kernel_kind<cube>, pto.aicore} {
 %c0 = arith.constant 0 : i64

 // This should fail - UB is not a valid destination for TLOAD.MAT
 %dst_tile = pto.alloc_tile addr = %c0 : !pto.tile_buf<ub, 16x32xf16, blayout=col_major, slayout=row_major>

 %dst_ptr = pto.tile_buf_addr %dst_tile : !pto.tile_buf<ub, 16x32xf16, blayout=col_major, slayout=row_major> -> !pto.ptr<f16, ub>

 // This should NOT match TLOAD.MAT template because destination is UB, not MAT
 pto.tload %src_gm, %dst_ptr : !pto.ptr<f16, gm>, !pto.ptr<f16, ub>

 pto.barrier #pto.pipe<PIPE_ALL>
 return
 }
}

// CHECK: error: no matching template for pto.tload
// CHECK-SAME: memory space constraint