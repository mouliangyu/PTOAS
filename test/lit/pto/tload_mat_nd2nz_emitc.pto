// RUN: ptoas --pto-arch=a5 --pto-backend=vpto --emit-vpto --mlir-print-ir-before=vpto-expand-wrapper-ops %s -o /dev/null 2>&1 | FileCheck %s --check-prefix=ROUNDTRIP

// Test TLOAD.MAT ND2NZ template - GM → L1 (MAT) with ND2NZ fractal load

module attributes {pto.target_arch = "a5", pto.kernel_kind = #pto.kernel_kind<cube>} {
 func.func @tload_mat_nd2nz_f16(%src_gm: memref<?xf16, #pto.address_space<gm>>,
                                 %dst_l1: memref<?xf16, #pto.address_space<mat>>) {
  %c0 = arith.constant 0 : i64
  %c1 = arith.constant 1 : i64
  %c16 = arith.constant 16 : i64
  %c32 = arith.constant 32 : i64
  %false = arith.constant false

  // Use mte_gm_l1_frac for ND2NZ
  pto.mte_gm_l1_frac %src_gm, %dst_l1, nd2nz,
   shape(%c16, %c32),
   src_layout(%c32),
   dst_group(%c1, %c1, %c16, %c0),
   ctrl(%c0, %false)
   : memref<?xf16, #pto.address_space<gm>>, memref<?xf16, #pto.address_space<mat>>, nd2nz,
    shape i64, i64, src_layout(i64),
    dst_group i64, i64, i64, i64, ctrl i64, i1

  return
 }
}

// ROUNDTRIP-LABEL: func.func @tload_mat_nd2nz_f16(
// ROUNDTRIP: pto.mte_gm_l1_frac
// ROUNDTRIP: nd2nz