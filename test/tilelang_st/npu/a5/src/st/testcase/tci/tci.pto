    pto.tstore ins(%tile : !pto.tile_buf<loc=vec, dtype=i32, rows=1, cols=72, v_row=1, v_col=72,
                                         blayout=row_major, slayout=none_box, fractal=512, pad=0>)
               outs(%dst_part : !pto.partition_tensor_view<1x1x1x1x72xi32>)
    return
  }

  // Two chunks: one full VReg + partial tail of 16 lanes.
  func.func @TCI_i32_1x80(%start: i32, %dst_ptr: !pto.ptr<i32>) {
