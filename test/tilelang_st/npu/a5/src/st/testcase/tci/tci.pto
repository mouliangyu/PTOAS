                                       blayout=row_major, slayout=none_box, fractal=512, pad=0>)
    pto.tstore ins(%tile : !pto.tile_buf<loc=vec, dtype=i32, rows=1, cols=80, v_row=1, v_col=80,
                                         blayout=row_major, slayout=none_box, fractal=512, pad=0>)
               outs(%dst_part : !pto.partition_tensor_view<1x1x1x1x80xi32>)
    return
  }

