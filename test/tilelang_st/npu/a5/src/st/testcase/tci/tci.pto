      : !pto.tile_buf<loc=vec, dtype=i16, rows=1, cols=16, v_row=1, v_col=16,
                      blayout=row_major, slayout=none_box, fractal=512, pad=0>

    pto.tci ins(%start : i16)
            outs(%tile : !pto.tile_buf<loc=vec, dtype=i16, rows=1, cols=16, v_row=1, v_col=16,
                                       blayout=row_major, slayout=none_box, fractal=512, pad=0>)
    pto.tstore ins(%tile : !pto.tile_buf<loc=vec, dtype=i16, rows=1, cols=16, v_row=1, v_col=16,
                                         blayout=row_major, slayout=none_box, fractal=512, pad=0>)
               outs(%dst_part : !pto.partition_tensor_view<1x1x1x1x16xi16>)
    return
  }

