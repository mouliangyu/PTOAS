// TileLang ST kernels for pto.trandom: Philox random number generator.
// Multiple cases with different shapes in a single module.
// Compiled by ptoas --enable-insert-sync --enable-tile-op-expand --vpto-emit-hivm-llvm
// to produce LLVM IR.

module {
  // Case 0: ui32 4x256 (1024 elements)
  func.func @TRANDOM_ui32_4x256(%out_ptr: !pto.ptr<ui32>, %key_ptr: !pto.ptr<ui32>, %counter_ptr: !pto.ptr<ui32>) {
    %c0    = arith.constant 0    : index
    %c1    = arith.constant 1    : index
    %c4    = arith.constant 4    : index
    %c256  = arith.constant 256  : index
    %c1024 = arith.constant 1024 : index
    %c2    = arith.constant 2    : index
    %c512  = arith.constant 512  : index

    %out_view = pto.make_tensor_view %out_ptr,
      shape = [%c1, %c1, %c1, %c4, %c256],
      strides = [%c1024, %c1024, %c1024, %c256, %c1]
      : !pto.tensor_view<1x1x1x4x256xui32>

    %out_part = pto.partition_view %out_view,
      offsets = [%c0, %c0, %c0, %c0, %c0],
      sizes = [%c1, %c1, %c1, %c4, %c256]
      : !pto.tensor_view<1x1x1x4x256xui32> -> !pto.partition_tensor_view<1x1x1x4x256xui32>

    %dst = pto.alloc_tile
      : !pto.tile_buf<loc=vec, dtype=ui32, rows=4, cols=256, v_row=4, v_col=256,
                      blayout=row_major, slayout=none_box, fractal=512, pad=0>
    %seed = pto.alloc_tile
      : !pto.tile_buf<loc=vec, dtype=ui32, rows=1, cols=2, v_row=1, v_col=2,
                      blayout=row_major, slayout=none_box, fractal=512, pad=0>
    %counter = pto.alloc_tile
      : !pto.tile_buf<loc=vec, dtype=ui32, rows=1, cols=4, v_row=1, v_col=4,
                      blayout=row_major, slayout=none_box, fractal=512, pad=0>

    %key_view = pto.make_tensor_view %key_ptr,
      shape = [%c1, %c1, %c1, %c1, %c2],
      strides = [%c2, %c2, %c2, %c2, %c1]
      : !pto.tensor_view<1x1x1x1x2xui32>

    %key_part = pto.partition_view %key_view,
      offsets = [%c0, %c0, %c0, %c0, %c0],
      sizes = [%c1, %c1, %c1, %c1, %c2]
      : !pto.tensor_view<1x1x1x1x2xui32> -> !pto.partition_tensor_view<1x1x1x1x2xui32>

    %counter_view = pto.make_tensor_view %counter_ptr,
      shape = [%c1, %c1, %c1, %c1, %c4],
      strides = [%c4, %c4, %c4, %c4, %c1]
      : !pto.tensor_view<1x1x1x1x4xui32>

    %counter_part = pto.partition_view %counter_view,
      offsets = [%c0, %c0, %c0, %c0, %c0],
      sizes = [%c1, %c1, %c1, %c1, %c4]
      : !pto.tensor_view<1x1x1x1x4xui32> -> !pto.partition_tensor_view<1x1x1x1x4xui32>

    pto.tload ins(%key_part : !pto.partition_tensor_view<1x1x1x1x2xui32>)
              outs(%seed : !pto.tile_buf<loc=vec, dtype=ui32, rows=1, cols=2, v_row=1, v_col=2,
                                      blayout=row_major, slayout=none_box, fractal=512, pad=0>)

    pto.tload ins(%counter_part : !pto.partition_tensor_view<1x1x1x1x4xui32>)
              outs(%counter : !pto.tile_buf<loc=vec, dtype=ui32, rows=1, cols=4, v_row=1, v_col=4,
                                      blayout=row_major, slayout=none_box, fractal=512, pad=0>)

    pto.trandom ins(%seed, %counter : !pto.tile_buf<loc=vec, dtype=ui32, rows=1, cols=2, v_row=1, v_col=2,
                                        blayout=row_major, slayout=none_box, fractal=512, pad=0>,
                            !pto.tile_buf<loc=vec, dtype=ui32, rows=1, cols=4, v_row=1, v_col=4,
                                        blayout=row_major, slayout=none_box, fractal=512, pad=0>)
                outs(%dst : !pto.tile_buf<loc=vec, dtype=ui32, rows=4, cols=256, v_row=4, v_col=256,
                                        blayout=row_major, slayout=none_box, fractal=512, pad=0>)

    pto.tstore ins(%dst : !pto.tile_buf<loc=vec, dtype=ui32, rows=4, cols=256, v_row=4, v_col=256,
                                      blayout=row_major, slayout=none_box, fractal=512, pad=0>)
               outs(%out_part : !pto.partition_tensor_view<1x1x1x4x256xui32>)
    return
  }
}