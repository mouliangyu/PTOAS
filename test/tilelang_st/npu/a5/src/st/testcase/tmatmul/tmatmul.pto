// Low-level VPTO cube matmul flow (conceptual):
// GM -> L1(copy_gm_to_cbuf_align_v2) -> L0A/L0B(load_cbuf_to_ca/cb)
// -> L0C(vmatmul) -> GM(copy_matrix_cc_to_gm)
module attributes {pto.target_arch = "a5"} {
  func.func @TMATMUL_f16f16_to_f32_32x32(%a_gm: !pto.ptr<f16, gm>,
                                         %b_gm: !pto.ptr<f16, gm>,
                                         %c_gm: !pto.ptr<f32, gm>) {
    %c0_i64 = arith.constant 0 : i64
    %c1_i64 = arith.constant 1 : i64
    %c32_i64 = arith.constant 32 : i64
    %c2048_i64 = arith.constant 2048 : i64
    %c4096_i64 = arith.constant 4096 : i64
    %c6144_i64 = arith.constant 6144 : i64
    %c8192_i64 = arith.constant 8192 : i64

    // Scratch pointers on UB. These represent low-level pipeline stages.
    %l1_a = pto.castptr %c0_i64 : i64 -> !pto.ptr<f16, ub>
    %l1_b = pto.castptr %c2048_i64 : i64 -> !pto.ptr<f16, ub>
    %l0a = pto.castptr %c4096_i64 : i64 -> !pto.ptr<f16, ub>
    %l0b = pto.castptr %c6144_i64 : i64 -> !pto.ptr<f16, ub>
    %l0c = pto.castptr %c8192_i64 : i64 -> !pto.ptr<f32, ub>

    pto.copy_gm_to_cbuf_align_v2 %a_gm, %l1_a, %c1_i64, %c32_i64, %c0_i64, %c0_i64
        : !pto.ptr<f16, gm>, !pto.ptr<f16, ub>, i64, i64, i64, i64
    pto.copy_gm_to_cbuf_align_v2 %b_gm, %l1_b, %c1_i64, %c32_i64, %c0_i64, %c0_i64
        : !pto.ptr<f16, gm>, !pto.ptr<f16, ub>, i64, i64, i64, i64
    pto.load_cbuf_to_ca %l1_a, %l0a, %c32_i64, %c32_i64
        : !pto.ptr<f16, ub>, !pto.ptr<f16, ub>, i64, i64
    pto.load_cbuf_to_cb %l1_b, %l0b, %c32_i64, %c32_i64
        : !pto.ptr<f16, ub>, !pto.ptr<f16, ub>, i64, i64
    pto.vmatmul %l0a, %l0b, %l0c, %c32_i64, %c32_i64, %c32_i64
        : !pto.ptr<f16, ub>, !pto.ptr<f16, ub>, !pto.ptr<f32, ub>, i64, i64, i64
    pto.copy_matrix_cc_to_gm %l0c, %c_gm, %c32_i64, %c32_i64
        : !pto.ptr<f32, ub>, !pto.ptr<f32, gm>, i64, i64

    return
  }
}
