// TileLang ST kernel for textract Vec->Vec ND (UB sub-window copy).
//
// kernel_kind=vector (pure vec path, no cube needed).
// Pipeline: mte_gm_ub(src) → textract(src_vec→dst_vec) → mte_ub_gm(dst)

module attributes {pto.target_arch = "a5", pto.kernel_kind = #pto.kernel_kind<vector>} {

  func.func @TEXTRACT_V2V_ND_f32_16x16(%src_gm: !pto.ptr<f32, gm>, %out_gm: !pto.ptr<f32, gm>) attributes {pto.aicore} {
    %c0_i64    = arith.constant 0    : i64
    %c1_i64    = arith.constant 1    : i64
    %c16_i64   = arith.constant 16   : i64
    %c64_i64   = arith.constant 64   : i64
    %c256_i64  = arith.constant 256  : i64
    %c0_index  = arith.constant 0    : index

    // --- tile allocations (both in UB = vec) ---
    %src_vec = pto.alloc_tile addr = %c0_i64
      : !pto.tile_buf<vec, 16x16xf32, blayout=row_major, slayout=none_box>
    %dst_vec = pto.alloc_tile addr = %c0_i64
      : !pto.tile_buf<vec, 16x16xf32, blayout=row_major, slayout=none_box>

    // --- pointers ---
    %src_ub = pto.tile_buf_addr %src_vec
      : !pto.tile_buf<vec, 16x16xf32, blayout=row_major, slayout=none_box>
     -> !pto.ptr<f32, ub>
    %dst_ub = pto.tile_buf_addr %dst_vec
      : !pto.tile_buf<vec, 16x16xf32, blayout=row_major, slayout=none_box>
     -> !pto.ptr<f32, ub>

    // --- GM -> UB: load source data ---
    pto.mte_gm_ub %src_gm, %src_ub, %c0_i64, %c256_i64
      nburst(%c16_i64, %c1_i64, %c1_i64)
      : !pto.ptr<f32, gm>, !pto.ptr<f32, ub>, i64, i64, i64, i64, i64

    // --- textract: src_vec -> dst_vec (offset=0, full copy) ---
    pto.textract ins(%src_vec, %c0_index, %c0_index : !pto.tile_buf<vec, 16x16xf32, blayout=row_major, slayout=none_box>, index, index)
                outs(%dst_vec : !pto.tile_buf<vec, 16x16xf32, blayout=row_major, slayout=none_box>)

    // --- UB -> GM: readback result ---
    pto.mte_ub_gm %dst_ub, %out_gm, %c256_i64
      nburst(%c16_i64, %c1_i64, %c1_i64)
      : !pto.ptr<f32, ub>, !pto.ptr<f32, gm>, i64, i64, i64, i64

    pto.barrier #pto.pipe<PIPE_ALL>
    return
  }

  }