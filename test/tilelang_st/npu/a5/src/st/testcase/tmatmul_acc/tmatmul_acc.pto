// Cube matmul Split-K kernel using mad/mad_acc directly with addptr for K-chunk offsets.
// Computes C[M,N] = A[M,K] x B[K,N] by splitting K into BASEK-sized chunks.
//   Pass 0: mad (zero-init)   -> L0C = A[:,0:BASEK] x B[0:BASEK,:]
//   Pass 1+: mad_acc (accumulate) -> L0C += A[:,i*BASEK:(i+1)*BASEK] x B[i*BASEK:(i+1)*BASEK,:]

module attributes {pto.target_arch = "a5", pto.kernel_kind = #pto.kernel_kind<cube>} {

  // Case: M=16, K=32, N=16, BASEK=16, iter=2
  // A[16,32] row stride = 64 bytes, B[32,16] row stride = 32 bytes
  func.func @TMATMUL_ACC_f16_16x32x16(%a_gm: !pto.ptr<f16, gm>, %b_gm: !pto.ptr<f16, gm>, %c_gm: !pto.ptr<f32, gm>) attributes {pto.aicore} {
    %c0_i64 = arith.constant 0 : i64
    %c1_i64 = arith.constant 1 : i64
    %c16_i64 = arith.constant 16 : i64
    %c32_i64 = arith.constant 32 : i64
    %c64_i64 = arith.constant 64 : i64
    %c512_i64 = arith.constant 512 : i64
    %c0_index = arith.constant 0 : index
    %c16_index = arith.constant 16 : index
    %c256_index = arith.constant 256 : index
    %false = arith.constant false

    %l1_a = pto.castptr %c0_i64 : i64 -> !pto.ptr<f16, l1>
    %l1_b = pto.castptr %c512_i64 : i64 -> !pto.ptr<f16, l1>
    %l0a = pto.castptr %c0_i64 : i64 -> !pto.ptr<f16, l0a>
    %l0b = pto.castptr %c0_i64 : i64 -> !pto.ptr<f16, l0b>
    %l0c = pto.castptr %c0_i64 : i64 -> !pto.ptr<f32, l0c>

    // ---- Pass 0: A[:,0:16], B[0:16,:] ----
    %a0 = pto.addptr %a_gm, %c0_index : !pto.ptr<f16, gm> -> !pto.ptr<f16, gm>
    %b0 = pto.addptr %b_gm, %c0_index : !pto.ptr<f16, gm> -> !pto.ptr<f16, gm>

    pto.mte_gm_l1_frac %a0, %l1_a, nd2nz,
      shape(%c16_i64, %c16_i64),
      src_layout(%c64_i64),
      dst_group(%c1_i64, %c1_i64, %c16_i64, %c0_i64),
      ctrl(%c0_i64, %false)
      : !pto.ptr<f16, gm>, !pto.ptr<f16, l1>, nd2nz,
        shape i64, i64, src_layout(i64),
        dst_group i64, i64, i64, i64, ctrl i64, i1
    pto.mte_gm_l1_frac %b0, %l1_b, nd2nz,
      shape(%c16_i64, %c16_i64),
      src_layout(%c32_i64),
      dst_group(%c1_i64, %c1_i64, %c16_i64, %c0_i64),
      ctrl(%c0_i64, %false)
      : !pto.ptr<f16, gm>, !pto.ptr<f16, l1>, nd2nz,
        shape i64, i64, src_layout(i64),
        dst_group i64, i64, i64, i64, ctrl i64, i1

    pto.set_flag["PIPE_MTE2", "PIPE_MTE1", "EVENT_ID0"]
    pto.wait_flag["PIPE_MTE2", "PIPE_MTE1", "EVENT_ID0"]
    pto.mte_l1_l0a %l1_a, %l0a, %c16_i64, %c16_i64
      : !pto.ptr<f16, l1>, !pto.ptr<f16, l0a>, i64, i64
    pto.mte_l1_l0b %l1_b, %l0b, %c16_i64, %c16_i64 {transpose = true}
      : !pto.ptr<f16, l1>, !pto.ptr<f16, l0b>, i64, i64

    pto.set_flag["PIPE_MTE1", "PIPE_M", "EVENT_ID0"]
    pto.wait_flag["PIPE_MTE1", "PIPE_M", "EVENT_ID0"]
    pto.mad %l0a, %l0b, %l0c, %c16_i64, %c16_i64, %c16_i64 disable_gemv
      : !pto.ptr<f16, l0a>, !pto.ptr<f16, l0b>, !pto.ptr<f32, l0c>, i64, i64, i64

    pto.set_flag["PIPE_M", "PIPE_MTE2", "EVENT_ID0"]
    pto.wait_flag["PIPE_M", "PIPE_MTE2", "EVENT_ID0"]

    // ---- Pass 1: A[:,16:32], B[16:32,:] ----
    // A offset = 16 f16 elements (column offset within row-major A[16,32])
    // B offset = 16*16 = 256 f16 elements (skip 16 rows of B[32,16])
    %a1 = pto.addptr %a_gm, %c16_index : !pto.ptr<f16, gm> -> !pto.ptr<f16, gm>
    %b1 = pto.addptr %b_gm, %c256_index : !pto.ptr<f16, gm> -> !pto.ptr<f16, gm>

    pto.mte_gm_l1_frac %a1, %l1_a, nd2nz,
      shape(%c16_i64, %c16_i64),
      src_layout(%c64_i64),
      dst_group(%c1_i64, %c1_i64, %c16_i64, %c0_i64),
      ctrl(%c0_i64, %false)
      : !pto.ptr<f16, gm>, !pto.ptr<f16, l1>, nd2nz,
        shape i64, i64, src_layout(i64),
        dst_group i64, i64, i64, i64, ctrl i64, i1
    pto.mte_gm_l1_frac %b1, %l1_b, nd2nz,
      shape(%c16_i64, %c16_i64),
      src_layout(%c32_i64),
      dst_group(%c1_i64, %c1_i64, %c16_i64, %c0_i64),
      ctrl(%c0_i64, %false)
      : !pto.ptr<f16, gm>, !pto.ptr<f16, l1>, nd2nz,
        shape i64, i64, src_layout(i64),
        dst_group i64, i64, i64, i64, ctrl i64, i1

    pto.set_flag["PIPE_MTE2", "PIPE_MTE1", "EVENT_ID1"]
    pto.wait_flag["PIPE_MTE2", "PIPE_MTE1", "EVENT_ID1"]
    pto.mte_l1_l0a %l1_a, %l0a, %c16_i64, %c16_i64
      : !pto.ptr<f16, l1>, !pto.ptr<f16, l0a>, i64, i64
    pto.mte_l1_l0b %l1_b, %l0b, %c16_i64, %c16_i64 {transpose = true}
      : !pto.ptr<f16, l1>, !pto.ptr<f16, l0b>, i64, i64

    pto.set_flag["PIPE_MTE1", "PIPE_M", "EVENT_ID1"]
    pto.wait_flag["PIPE_MTE1", "PIPE_M", "EVENT_ID1"]
    pto.mad_acc %l0a, %l0b, %l0c, %c16_i64, %c16_i64, %c16_i64 disable_gemv
      : !pto.ptr<f16, l0a>, !pto.ptr<f16, l0b>, !pto.ptr<f32, l0c>, i64, i64, i64

    pto.set_flag["PIPE_M", "PIPE_FIX", "EVENT_ID1"]
    pto.wait_flag["PIPE_M", "PIPE_FIX", "EVENT_ID1"]
    pto.mte_l0c_gm %l0c, %c_gm, %c16_i64, %c16_i64, %c16_i64, %c16_i64, %c0_i64, %c0_i64, nz2nd
      : !pto.ptr<f32, l0c>, !pto.ptr<f32, gm>, i64, i64, i64, i64, i64, i64
    pto.barrier #pto.pipe<PIPE_ALL>
    return
  }

  // Case: M=128, K=128, N=64, BASEK=64, iter=2
  // A[128,128] row stride = 256 bytes, B[128,64] row stride = 128 bytes
  func.func @TMATMUL_ACC_f16_128x128x64(%a_gm: !pto.ptr<f16, gm>, %b_gm: !pto.ptr<f16, gm>, %c_gm: !pto.ptr<f32, gm>) attributes {pto.aicore} {
    %c0_i64 = arith.constant 0 : i64
    %c1_i64 = arith.constant 1 : i64
    %c64_i64 = arith.constant 64 : i64
    %c128_i64 = arith.constant 128 : i64
    %c256_i64 = arith.constant 256 : i64
    %c16384_i64 = arith.constant 16384 : i64
    %c0_index = arith.constant 0 : index
    %c64_index = arith.constant 64 : index
    %c4096_index = arith.constant 4096 : index
    %false = arith.constant false

    %l1_a = pto.castptr %c0_i64 : i64 -> !pto.ptr<f16, l1>
    %l1_b = pto.castptr %c16384_i64 : i64 -> !pto.ptr<f16, l1>
    %l0a = pto.castptr %c0_i64 : i64 -> !pto.ptr<f16, l0a>
    %l0b = pto.castptr %c0_i64 : i64 -> !pto.ptr<f16, l0b>
    %l0c = pto.castptr %c0_i64 : i64 -> !pto.ptr<f32, l0c>

    // ---- Pass 0: A[:,0:64], B[0:64,:] ----
    %a0 = pto.addptr %a_gm, %c0_index : !pto.ptr<f16, gm> -> !pto.ptr<f16, gm>
    %b0 = pto.addptr %b_gm, %c0_index : !pto.ptr<f16, gm> -> !pto.ptr<f16, gm>

    pto.mte_gm_l1_frac %a0, %l1_a, nd2nz,
      shape(%c128_i64, %c64_i64),
      src_layout(%c256_i64),
      dst_group(%c1_i64, %c1_i64, %c128_i64, %c0_i64),
      ctrl(%c0_i64, %false)
      : !pto.ptr<f16, gm>, !pto.ptr<f16, l1>, nd2nz,
        shape i64, i64, src_layout(i64),
        dst_group i64, i64, i64, i64, ctrl i64, i1
    pto.mte_gm_l1_frac %b0, %l1_b, nd2nz,
      shape(%c64_i64, %c64_i64),
      src_layout(%c128_i64),
      dst_group(%c1_i64, %c1_i64, %c64_i64, %c0_i64),
      ctrl(%c0_i64, %false)
      : !pto.ptr<f16, gm>, !pto.ptr<f16, l1>, nd2nz,
        shape i64, i64, src_layout(i64),
        dst_group i64, i64, i64, i64, ctrl i64, i1

    pto.set_flag["PIPE_MTE2", "PIPE_MTE1", "EVENT_ID0"]
    pto.wait_flag["PIPE_MTE2", "PIPE_MTE1", "EVENT_ID0"]
    pto.mte_l1_l0a %l1_a, %l0a, %c128_i64, %c64_i64
      : !pto.ptr<f16, l1>, !pto.ptr<f16, l0a>, i64, i64
    pto.mte_l1_l0b %l1_b, %l0b, %c64_i64, %c64_i64 {transpose = true}
      : !pto.ptr<f16, l1>, !pto.ptr<f16, l0b>, i64, i64

    pto.set_flag["PIPE_MTE1", "PIPE_M", "EVENT_ID0"]
    pto.wait_flag["PIPE_MTE1", "PIPE_M", "EVENT_ID0"]
    pto.mad %l0a, %l0b, %l0c, %c128_i64, %c64_i64, %c64_i64 disable_gemv
      : !pto.ptr<f16, l0a>, !pto.ptr<f16, l0b>, !pto.ptr<f32, l0c>, i64, i64, i64

    pto.set_flag["PIPE_M", "PIPE_MTE2", "EVENT_ID0"]
    pto.wait_flag["PIPE_M", "PIPE_MTE2", "EVENT_ID0"]

    // ---- Pass 1: A[:,64:128], B[64:128,:] ----
    // A offset = 64 f16 elements (column offset within row-major A[128,128])
    // B offset = 64*64 = 4096 f16 elements (skip 64 rows of B[128,64])
    %a1 = pto.addptr %a_gm, %c64_index : !pto.ptr<f16, gm> -> !pto.ptr<f16, gm>
    %b1 = pto.addptr %b_gm, %c4096_index : !pto.ptr<f16, gm> -> !pto.ptr<f16, gm>

    pto.mte_gm_l1_frac %a1, %l1_a, nd2nz,
      shape(%c128_i64, %c64_i64),
      src_layout(%c256_i64),
      dst_group(%c1_i64, %c1_i64, %c128_i64, %c0_i64),
      ctrl(%c0_i64, %false)
      : !pto.ptr<f16, gm>, !pto.ptr<f16, l1>, nd2nz,
        shape i64, i64, src_layout(i64),
        dst_group i64, i64, i64, i64, ctrl i64, i1
    pto.mte_gm_l1_frac %b1, %l1_b, nd2nz,
      shape(%c64_i64, %c64_i64),
      src_layout(%c128_i64),
      dst_group(%c1_i64, %c1_i64, %c64_i64, %c0_i64),
      ctrl(%c0_i64, %false)
      : !pto.ptr<f16, gm>, !pto.ptr<f16, l1>, nd2nz,
        shape i64, i64, src_layout(i64),
        dst_group i64, i64, i64, i64, ctrl i64, i1

    pto.set_flag["PIPE_MTE2", "PIPE_MTE1", "EVENT_ID1"]
    pto.wait_flag["PIPE_MTE2", "PIPE_MTE1", "EVENT_ID1"]
    pto.mte_l1_l0a %l1_a, %l0a, %c128_i64, %c64_i64
      : !pto.ptr<f16, l1>, !pto.ptr<f16, l0a>, i64, i64
    pto.mte_l1_l0b %l1_b, %l0b, %c64_i64, %c64_i64 {transpose = true}
      : !pto.ptr<f16, l1>, !pto.ptr<f16, l0b>, i64, i64

    pto.set_flag["PIPE_MTE1", "PIPE_M", "EVENT_ID1"]
    pto.wait_flag["PIPE_MTE1", "PIPE_M", "EVENT_ID1"]
    pto.mad_acc %l0a, %l0b, %l0c, %c128_i64, %c64_i64, %c64_i64 unit_flag(check_and_set) disable_gemv
      : !pto.ptr<f16, l0a>, !pto.ptr<f16, l0b>, !pto.ptr<f32, l0c>, i64, i64, i64

    pto.set_flag["PIPE_M", "PIPE_FIX", "EVENT_ID1"]
    pto.wait_flag["PIPE_M", "PIPE_FIX", "EVENT_ID1"]
    pto.mte_l0c_gm %l0c, %c_gm, %c128_i64, %c64_i64, %c128_i64, %c64_i64, %c0_i64, %c0_i64, nz2nd
      : !pto.ptr<f32, l0c>, !pto.ptr<f32, gm>, i64, i64, i64, i64, i64, i64
    pto.barrier #pto.pipe<PIPE_ALL>
    return
  }

  // Case: M=127, K=128, N=61, BASEK=64, iter=2
  // A[128,128] row stride = 256 bytes (padded from 127 to 128 rows),
  // B[128,64] row stride = 128 bytes (padded from 61 to 64 cols)
  func.func @TMATMUL_ACC_f16_127x128x61(%a_gm: !pto.ptr<f16, gm>, %b_gm: !pto.ptr<f16, gm>, %c_gm: !pto.ptr<f32, gm>) attributes {pto.aicore} {
    %c0_i64 = arith.constant 0 : i64
    %c1_i64 = arith.constant 1 : i64
    %c64_i64 = arith.constant 64 : i64
    %c61_i64 = arith.constant 61 : i64
    %c127_i64 = arith.constant 127 : i64
    %c128_i64 = arith.constant 128 : i64
    %c256_i64 = arith.constant 256 : i64
    %c16384_i64 = arith.constant 16384 : i64
    %c0_index = arith.constant 0 : index
    %c64_index = arith.constant 64 : index
    %c4096_index = arith.constant 4096 : index
    %false = arith.constant false

    %l1_a = pto.castptr %c0_i64 : i64 -> !pto.ptr<f16, l1>
    %l1_b = pto.castptr %c16384_i64 : i64 -> !pto.ptr<f16, l1>
    %l0a = pto.castptr %c0_i64 : i64 -> !pto.ptr<f16, l0a>
    %l0b = pto.castptr %c0_i64 : i64 -> !pto.ptr<f16, l0b>
    %l0c = pto.castptr %c0_i64 : i64 -> !pto.ptr<f32, l0c>

    // ---- Pass 0: A[:,0:64], B[0:64,:] ----
    %a0 = pto.addptr %a_gm, %c0_index : !pto.ptr<f16, gm> -> !pto.ptr<f16, gm>
    %b0 = pto.addptr %b_gm, %c0_index : !pto.ptr<f16, gm> -> !pto.ptr<f16, gm>

    pto.mte_gm_l1_frac %a0, %l1_a, nd2nz,
      shape(%c128_i64, %c64_i64),
      src_layout(%c256_i64),
      dst_group(%c1_i64, %c1_i64, %c128_i64, %c0_i64),
      ctrl(%c0_i64, %false)
      : !pto.ptr<f16, gm>, !pto.ptr<f16, l1>, nd2nz,
        shape i64, i64, src_layout(i64),
        dst_group i64, i64, i64, i64, ctrl i64, i1
    pto.mte_gm_l1_frac %b0, %l1_b, nd2nz,
      shape(%c64_i64, %c64_i64),
      src_layout(%c128_i64),
      dst_group(%c1_i64, %c1_i64, %c64_i64, %c0_i64),
      ctrl(%c0_i64, %false)
      : !pto.ptr<f16, gm>, !pto.ptr<f16, l1>, nd2nz,
        shape i64, i64, src_layout(i64),
        dst_group i64, i64, i64, i64, ctrl i64, i1

    pto.set_flag["PIPE_MTE2", "PIPE_MTE1", "EVENT_ID0"]
    pto.wait_flag["PIPE_MTE2", "PIPE_MTE1", "EVENT_ID0"]
    pto.mte_l1_l0a %l1_a, %l0a, %c128_i64, %c64_i64
      : !pto.ptr<f16, l1>, !pto.ptr<f16, l0a>, i64, i64
    pto.mte_l1_l0b %l1_b, %l0b, %c64_i64, %c64_i64 {transpose = true}
      : !pto.ptr<f16, l1>, !pto.ptr<f16, l0b>, i64, i64

    pto.set_flag["PIPE_MTE1", "PIPE_M", "EVENT_ID0"]
    pto.wait_flag["PIPE_MTE1", "PIPE_M", "EVENT_ID0"]
    pto.mad %l0a, %l0b, %l0c, %c128_i64, %c64_i64, %c64_i64 disable_gemv
      : !pto.ptr<f16, l0a>, !pto.ptr<f16, l0b>, !pto.ptr<f32, l0c>, i64, i64, i64

    pto.set_flag["PIPE_M", "PIPE_MTE2", "EVENT_ID0"]
    pto.wait_flag["PIPE_M", "PIPE_MTE2", "EVENT_ID0"]

    // ---- Pass 1: A[:,64:128], B[64:128,:] ----
    // A offset = 64 f16 elements (column offset within row-major A[128,128])
    // B offset = 64*64 = 4096 f16 elements (skip 64 rows of B[128,64])
    %a1 = pto.addptr %a_gm, %c64_index : !pto.ptr<f16, gm> -> !pto.ptr<f16, gm>
    %b1 = pto.addptr %b_gm, %c4096_index : !pto.ptr<f16, gm> -> !pto.ptr<f16, gm>

    pto.mte_gm_l1_frac %a1, %l1_a, nd2nz,
      shape(%c128_i64, %c64_i64),
      src_layout(%c256_i64),
      dst_group(%c1_i64, %c1_i64, %c128_i64, %c0_i64),
      ctrl(%c0_i64, %false)
      : !pto.ptr<f16, gm>, !pto.ptr<f16, l1>, nd2nz,
        shape i64, i64, src_layout(i64),
        dst_group i64, i64, i64, i64, ctrl i64, i1
    pto.mte_gm_l1_frac %b1, %l1_b, nd2nz,
      shape(%c64_i64, %c64_i64),
      src_layout(%c128_i64),
      dst_group(%c1_i64, %c1_i64, %c64_i64, %c0_i64),
      ctrl(%c0_i64, %false)
      : !pto.ptr<f16, gm>, !pto.ptr<f16, l1>, nd2nz,
        shape i64, i64, src_layout(i64),
        dst_group i64, i64, i64, i64, ctrl i64, i1

    pto.set_flag["PIPE_MTE2", "PIPE_MTE1", "EVENT_ID1"]
    pto.wait_flag["PIPE_MTE2", "PIPE_MTE1", "EVENT_ID1"]
    pto.mte_l1_l0a %l1_a, %l0a, %c128_i64, %c64_i64
      : !pto.ptr<f16, l1>, !pto.ptr<f16, l0a>, i64, i64
    pto.mte_l1_l0b %l1_b, %l0b, %c64_i64, %c64_i64 {transpose = true}
      : !pto.ptr<f16, l1>, !pto.ptr<f16, l0b>, i64, i64

    pto.set_flag["PIPE_MTE1", "PIPE_M", "EVENT_ID1"]
    pto.wait_flag["PIPE_MTE1", "PIPE_M", "EVENT_ID1"]
    pto.mad_acc %l0a, %l0b, %l0c, %c128_i64, %c64_i64, %c64_i64 disable_gemv
      : !pto.ptr<f16, l0a>, !pto.ptr<f16, l0b>, !pto.ptr<f32, l0c>, i64, i64, i64

    pto.set_flag["PIPE_M", "PIPE_FIX", "EVENT_ID1"]
    pto.wait_flag["PIPE_M", "PIPE_FIX", "EVENT_ID1"]
    pto.mte_l0c_gm %l0c, %c_gm, %c128_i64, %c64_i64, %c128_i64, %c64_i64, %c0_i64, %c0_i64, nz2nd
      : !pto.ptr<f32, l0c>, !pto.ptr<f32, gm>, i64, i64, i64, i64, i64, i64
    pto.barrier #pto.pipe<PIPE_ALL>
    return
  }
}